<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_kenocia_journal_bank_cash" model="ir.actions.act_window">
        <field name="name">Diarios banco y caja</field>
        <field name="res_model">account.journal</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', 'in', ('bank', 'cash'))]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure los diarios de banco y caja
            </p>
            <p>
                Revise la cuenta outstanding de cada método de pago y asigne
                las secuencias bancarias de tesorería por diario.
            </p>
        </field>
    </record>

    <record id="action_kenocia_advance_accounts" model="ir.actions.server">
        <field name="name">Cuentas de anticipo</field>
        <field name="model_id" ref="account.model_account_account"/>
        <field name="state">code</field>
        <field name="code">action = model.action_kenocia_open_advance_accounts()</field>
    </record>

    <record id="action_kenocia_chart_bank_cash" model="ir.actions.server">
        <field name="name">Cuentas banco y efectivo</field>
        <field name="model_id" ref="account.model_account_account"/>
        <field name="state">code</field>
        <field name="code">action = model.action_kenocia_open_bank_cash_accounts()</field>
    </record>

    <record id="action_kenocia_reconcile_manual" model="ir.actions.server">
        <field name="name">Conciliación manual</field>
        <field name="model_id" ref="account.model_account_move_line"/>
        <field name="state">code</field>
        <field name="code">action = model.action_kenocia_open_reconcile()</field>
    </record>

</odoo>
