<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_tree_kenocia_tesoreria" model="ir.ui.view">
        <field name="name">account.journal.list.kenocia.tesoreria</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_tree"/>
        <field name="arch" type="xml">
            <field name="type" position="after">
                <field name="kenocia_sequence_count" string="Secuencias" optional="show"/>
                <field name="kenocia_missing_payment_account" string="Falta outstanding" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="view_account_journal_form_kenocia_tesoreria" model="ir.ui.view">
        <field name="name">account.journal.form.kenocia.tesoreria</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="kenocia_missing_payment_account" invisible="1"/>
                <div class="alert alert-warning mb-0" role="alert"
                     invisible="not kenocia_missing_payment_account or type not in ('bank', 'cash')">
                    Algún método de pago de este diario no tiene cuenta de pagos pendientes
                    (outstanding). Los pagos pueden quedar sin asiento contable hasta configurarla.
                </div>
                <field name="kenocia_cheque_native_seq_coexist" invisible="1"/>
                <div class="alert alert-info mb-0" role="alert"
                     invisible="not kenocia_cheque_native_seq_coexist">
                    Este diario tiene activa la "Secuencia de pago dedicada" nativa y, además,
                    una secuencia Kenocia de cheque. Los cheques se numerarán con el
                    <b>correlativo Kenocia</b> (no con la serie PAY nativa). Es una coexistencia
                    válida; solo tenlo presente al conciliar.
                </div>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="kenocia_sequence_count" invisible="1"/>
                <button type="object"
                        name="action_view_kenocia_sequences"
                        class="oe_stat_button"
                        icon="fa-sort-numeric-asc"
                        invisible="kenocia_sequence_count == 0"
                        groups="kenocia_tesoreria_v18.group_tesoreria_supervisor,kenocia_tesoreria_v18.group_tesoreria_admin">
                    <field name="kenocia_sequence_count" widget="statinfo" string="Secuencias"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Tesorería Kenocia"
                      name="kenocia_tesoreria"
                      invisible="type not in ('bank', 'cash')"
                      groups="kenocia_tesoreria_v18.group_tesoreria_supervisor,kenocia_tesoreria_v18.group_tesoreria_admin">
                    <group>
                        <field name="kenocia_bank_format"
                               invisible="type != 'bank'"/>
                    </group>
                    <group>
                        <button name="action_kenocia_create_sequence"
                                type="object"
                                string="Nueva secuencia"
                                class="btn-primary mb-2"/>
                    </group>
                    <field name="kenocia_sequence_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="transaction_type"/>
                            <field name="prefix"/>
                            <field name="next_number"/>
                            <field name="padding"/>
                            <field name="preview"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
