<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_kenocia_tesoreria" model="ir.ui.view">
        <field name="name">res.company.form.kenocia.tesoreria</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']" position="after">
                <page string="Tesorería Kenocia" name="kenocia_tesoreria">
                    <group>
                        <group string="Cuentas de anticipo">
                            <field name="kenocia_advance_account_cxc_id"/>
                            <field name="kenocia_advance_account_cxp_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
