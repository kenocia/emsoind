<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_advance_payment_list" model="ir.ui.view">
        <field name="name">kenocia.advance.payment.list</field>
        <field name="model">kenocia.advance.payment</field>
        <field name="arch" type="xml">
            <list string="Adelantos"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'fully_applied'"
                  decoration-warning="state == 'partially_applied'">
                <field name="name"/>
                <field name="date"/>
                <field name="advance_type"/>
                <field name="partner_id" string="Cliente"/>
                <field name="amount" sum="Total"/>
                <field name="amount_applied"/>
                <field name="amount_residual"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'fully_applied'"
                       decoration-warning="state == 'partially_applied'"
                       decoration-info="state == 'confirmed'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_kenocia_advance_payment_search" model="ir.ui.view">
        <field name="name">kenocia.advance.payment.search</field>
        <field name="model">kenocia.advance.payment</field>
        <field name="arch" type="xml">
            <search string="Buscar adelantos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <field name="purchase_order_id"/>
                <filter name="customer" string="Clientes"
                        domain="[('advance_type', '=', 'customer')]"/>
                <filter name="supplier" string="Proveedores"
                        domain="[('advance_type', '=', 'supplier')]"/>
                <filter name="confirmed" string="Confirmados"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="with_residual" string="Con saldo"
                        domain="[('amount_residual', '&gt;', 0)]"/>
                <group>
                    <filter name="group_partner" string="Cliente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
