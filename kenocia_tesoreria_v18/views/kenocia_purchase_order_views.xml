<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_kenocia_advances" model="ir.ui.view">
        <field name="name">purchase.order.kenocia.advances</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_view_advances"
                        class="oe_stat_button kt_advance_btn" icon="fa-hand-holding-usd"
                        invisible="advance_count == 0"
                        groups="kenocia_tesoreria_v18.group_tesoreria_cxp,kenocia_tesoreria_v18.group_tesoreria_supervisor,kenocia_tesoreria_v18.group_tesoreria_admin">
                    <field name="advance_count" widget="statinfo" string="Anticipos"/>
                </button>
                <field name="advance_count" invisible="1"/>
                <field name="advance_amount_total" invisible="1"/>
                <field name="advance_residual" invisible="1"/>
                <field name="amount_due" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="after">
                <group string="Anticipos registrados" invisible="advance_count == 0"
                       groups="kenocia_tesoreria_v18.group_tesoreria_cxp,kenocia_tesoreria_v18.group_tesoreria_supervisor,kenocia_tesoreria_v18.group_tesoreria_admin">
                    <field name="advance_payment_ids" nolabel="1" readonly="1">
                        <list decoration-muted="state == 'cancelled'"
                              decoration-success="state == 'fully_applied'">
                            <field name="name"/>
                            <field name="date"/>
                            <field name="amount" sum="Total anticipo"/>
                            <field name="amount_residual" sum="Disponible"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </group>
            </xpath>
            <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="inside">
                <div class="d-flex justify-content-between text-muted kt_advance_total_line"
                     invisible="advance_amount_total == 0">
                    <span>Anticipo (-)</span>
                    <field name="advance_amount_total" widget="monetary" readonly="1"
                           class="text-success"/>
                </div>
                <div class="d-flex justify-content-between fw-bold border-top pt-2 kt_advance_due_line"
                     invisible="advance_amount_total == 0">
                    <span>Total a pagar</span>
                    <field name="amount_due" widget="monetary" readonly="1"/>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
