<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_kenocia_advance_receipt" model="ir.actions.report">
        <field name="name">Recibo de anticipo</field>
        <field name="model">kenocia.advance.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kenocia_tesoreria_v18.report_advance_receipt</field>
        <field name="report_file">kenocia_tesoreria_v18.report_advance_receipt</field>
        <field name="print_report_name">'Recibo de anticipo - %s' % (object.name or '')</field>
        <field name="paperformat_id" ref="kc_fiscal_hn_v18.paper_format_carta_hn"/>
        <field name="binding_model_id" ref="model_kenocia_advance_payment"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Encabezado estilo factura SAR EMSOIND -->
    <template id="header_advance_receipt_layout" name="Encabezado Recibo Anticipo">
        <t t-set="company" t-value="o.company_id"/>
        <t t-set="partner" t-value="o.partner_id.commercial_partner_id"/>
        <t t-set="emisor_ubicacion"
           t-value="', '.join([p for p in [company.city or '', company.state_id.name if company.state_id else '', company.country_id.name if company.country_id else ''] if p])"/>

        <table style="width:100%; border-collapse:collapse; margin-bottom:14px;">
            <tr>
                <td style="width:68%; vertical-align:top; padding:0;">
                    <div style="font-size:10px; letter-spacing:1.4px; color:#6b7280; text-transform:uppercase; margin-bottom:3px;">
                        Tesorería · <span t-out="o._get_advance_receipt_type_label()"/>
                    </div>
                    <div style="font-size:19px; font-weight:600; color:#111827; margin-bottom:5px; line-height:1.25;">
                        <span t-if="o.name and o.name != '/'" t-field="o.name"/>
                    </div>
                    <div style="font-size:11px; color:#4b5563; margin-bottom:8px;">
                        <span>Fecha de pago: </span>
                        <span style="font-weight:600; color:#111827;"
                              t-esc="o.date.strftime('%d/%m/%Y') if o.date else ''"/>
                    </div>
                    <span t-out="o._get_advance_receipt_type_label()"
                          style="display:inline-block; border:1px solid #1a4fa0; color:#1a4fa0; border-radius:10px; padding:2px 10px; font-size:10px; font-weight:600; letter-spacing:0.4px; -webkit-print-color-adjust:exact;"/>
                </td>
                <td style="width:32%; vertical-align:top; text-align:right; padding:0;">
                    <img t-if="company.logo"
                         t-att-src="image_data_uri(company.logo)"
                         style="max-height:72px; max-width:100%;" alt="Logo"/>
                </td>
            </tr>
        </table>

        <table style="width:100%; border-collapse:collapse; margin-bottom:14px;">
            <tr>
                <td style="width:50%; vertical-align:top; padding-right:6px;">
                    <div style="background-color:#f7f8fa; border:1px solid #e5e7eb; border-radius:6px; padding:10px 12px; min-height:118px; -webkit-print-color-adjust:exact;">
                        <div style="font-size:10px; letter-spacing:1px; color:#9ca3af; text-transform:uppercase; margin-bottom:4px;">
                            Emisor
                        </div>
                        <div style="font-weight:600; color:#111827; margin-bottom:4px;">
                            <span t-field="company.name"/>
                        </div>
                        <div style="color:#4b5563; margin-bottom:2px; font-size:10px; line-height:1.4;">
                            <span t-field="company.street"/>
                            <t t-if="company.street2">, <span t-field="company.street2"/></t>
                        </div>
                        <div style="color:#4b5563; margin-bottom:4px; font-size:10px;">
                            <span t-esc="emisor_ubicacion"/>
                        </div>
                        <t t-if="company.phone">
                            <div style="color:#4b5563; margin-bottom:2px; font-size:10px;">
                                Tel: <span t-field="company.phone"/>
                            </div>
                        </t>
                        <div style="color:#4b5563; font-size:10px;">
                            RTN:
                            <span style="font-family:'Courier New',monospace; font-weight:600; color:#111827;">
                                <span t-field="company.vat"/>
                            </span>
                        </div>
                    </div>
                </td>
                <td style="width:50%; vertical-align:top; padding-left:6px;">
                    <div style="background-color:#f7f8fa; border:1px solid #e5e7eb; border-radius:6px; padding:10px 12px; min-height:118px; -webkit-print-color-adjust:exact;">
                        <div style="font-size:10px; letter-spacing:1px; color:#9ca3af; text-transform:uppercase; margin-bottom:4px;">
                            <span t-out="o._get_advance_receipt_partner_label()"/>
                        </div>
                        <div style="font-weight:600; color:#111827; margin-bottom:6px; font-size:11px; line-height:1.35;">
                            <span t-field="partner.name"/>
                        </div>
                        <div style="color:#4b5563; font-size:10px; margin-bottom:4px;">
                            RTN:
                            <t t-if="partner.vat">
                                <span style="font-family:'Courier New',monospace; font-weight:600; color:#111827;">
                                    <span t-field="partner.vat"/>
                                </span>
                            </t>
                            <t t-else="">
                                <span style="color:#9ca3af;">—</span>
                            </t>
                        </div>
                        <t t-if="partner.street">
                            <div style="color:#4b5563; font-size:10px; line-height:1.35;">
                                <span t-field="partner.street"/>
                            </div>
                        </t>
                    </div>
                </td>
            </tr>
        </table>

        <table style="width:100%; border-collapse:collapse; margin-bottom:14px; font-size:10px; color:#4b5563;">
            <tr>
                <td style="width:25%; border:1px solid #dbeafe; background-color:#eff6ff; padding:8px 10px; -webkit-print-color-adjust:exact;">
                    <div style="font-size:9px; letter-spacing:0.8px; text-transform:uppercase; color:#6b7280; margin-bottom:2px;">
                        Método de pago
                    </div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-if="o.payment_id and o.payment_id.payment_method_id"
                              t-field="o.payment_id.payment_method_id.name"/>
                        <span t-else="" style="color:#9ca3af;">—</span>
                    </div>
                </td>
                <td style="width:25%; border:1px solid #dbeafe; background-color:#eff6ff; padding:8px 10px; -webkit-print-color-adjust:exact;">
                    <div style="font-size:9px; letter-spacing:0.8px; text-transform:uppercase; color:#6b7280; margin-bottom:2px;">
                        Número de pago
                    </div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-if="o.payment_id" t-field="o.payment_id.name"/>
                        <span t-else="" style="color:#9ca3af;">—</span>
                    </div>
                </td>
                <td style="width:25%; border:1px solid #dbeafe; background-color:#eff6ff; padding:8px 10px; -webkit-print-color-adjust:exact;">
                    <div style="font-size:9px; letter-spacing:0.8px; text-transform:uppercase; color:#6b7280; margin-bottom:2px;">
                        Diario
                    </div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-field="o.journal_id.name"/>
                    </div>
                </td>
                <td style="width:25%; border:1px solid #dbeafe; background-color:#eff6ff; padding:8px 10px; -webkit-print-color-adjust:exact;">
                    <div style="font-size:9px; letter-spacing:0.8px; text-transform:uppercase; color:#6b7280; margin-bottom:2px;">
                        Estado
                    </div>
                    <div style="font-weight:600; color:#1a4fa0;">
                        <span t-field="o.state"/>
                    </div>
                </td>
            </tr>
        </table>
    </template>

    <template id="report_advance_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang or o.company_id.partner_id.lang"/>
                <t t-call="kenocia_tesoreria_v18.report_advance_receipt_document" t-lang="lang"/>
            </t>
        </t>
    </template>

    <template id="report_advance_receipt_document">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="o.with_context(lang=lang)"/>
            <t t-set="values" t-value="o._get_advance_receipt_report_values()"/>
            <t t-set="receipt_documents" t-value="values.get('receipt_documents') or []"/>
            <div class="page" style="font-family: Arial, Helvetica, sans-serif; color:#111827;">
                <t t-call="kenocia_tesoreria_v18.header_advance_receipt_layout"/>

                <table style="width:100%; border-collapse:collapse; font-size:11px; color:#4b5563; margin-bottom:16px;"
                       name="advance_documents">
                    <thead>
                        <tr>
                            <th style="width:18%; text-align:left; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#6b7280; text-transform:uppercase; padding:7px 6px; border-bottom:2px solid #1a4fa0;">
                                Fecha
                            </th>
                            <th style="width:28%; text-align:left; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#6b7280; text-transform:uppercase; padding:7px 6px; border-bottom:2px solid #1a4fa0;">
                                Documento
                            </th>
                            <th style="width:34%; text-align:left; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#6b7280; text-transform:uppercase; padding:7px 6px; border-bottom:2px solid #1a4fa0;">
                                Referencia
                            </th>
                            <th style="width:20%; text-align:right; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#6b7280; text-transform:uppercase; padding:7px 6px; border-bottom:2px solid #1a4fa0;">
                                Importe
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="receipt_documents" t-as="doc">
                            <td style="padding:7px 6px; border-bottom:1px solid #eef0f3;">
                                <span t-out="doc['date']" t-options="{'widget': 'date'}"/>
                            </td>
                            <td style="padding:7px 6px; border-bottom:1px solid #eef0f3; font-weight:600; color:#111827;">
                                <span t-out="doc['name']"/>
                            </td>
                            <td style="padding:7px 6px; border-bottom:1px solid #eef0f3;">
                                <span t-out="doc['ref']"/>
                            </td>
                            <td style="padding:7px 6px; border-bottom:1px solid #eef0f3; text-align:right; font-weight:600; color:#111827;">
                                <span t-out="doc['amount']"
                                      t-options="{'widget': 'monetary', 'display_currency': doc['currency']}"/>
                            </td>
                        </tr>
                        <tr t-if="not receipt_documents">
                            <td colspan="4"
                                style="padding:14px 6px; border-bottom:1px solid #eef0f3; text-align:center; color:#9ca3af; font-style:italic;">
                                Sin facturas aplicadas al momento de la impresión.
                            </td>
                        </tr>
                    </tbody>
                </table>

                <table style="width:100%; border-collapse:collapse; page-break-inside:avoid;">
                    <tr>
                        <td style="width:58%; vertical-align:top; padding-right:12px; font-size:11px; color:#4b5563;">
                            <div style="font-weight:600; color:#1a4fa0; font-size:12px; margin-bottom:8px; letter-spacing:0.3px;">
                                Nota de anticipo
                            </div>
                            <t t-if="values.get('advance_note')">
                                <div style="background-color:#f7f8fa; border-left:3px solid #1a4fa0; padding:10px 12px; margin-bottom:10px; line-height:1.45; -webkit-print-color-adjust:exact;">
                                    <span t-out="values.get('advance_note')"/>
                                </div>
                            </t>
                            <div style="line-height:1.5; color:#6b7280; font-size:10px;">
                                <span t-out="values.get('advance_standard_note')"/>
                            </div>
                            <t t-if="o.payment_id and o.payment_id.amount_in_words">
                                <div style="margin-top:12px; padding-top:10px; border-top:1px dashed #e5e7eb; font-size:10px;">
                                    <strong style="color:#111827;">Monto en letras:</strong>
                                    <span t-field="o.payment_id.amount_in_words"/>
                                </div>
                            </t>
                            <t t-if="o.sale_order_id or o.purchase_order_id">
                                <div style="margin-top:10px; font-size:10px;">
                                    <strong style="color:#111827;">Orden vinculada:</strong>
                                    <span t-if="o.sale_order_id" t-field="o.sale_order_id.name"/>
                                    <span t-if="o.purchase_order_id" t-field="o.purchase_order_id.name"/>
                                </div>
                            </t>
                        </td>
                        <td style="width:42%; vertical-align:top;">
                            <table style="width:100%; border-collapse:collapse; font-size:11px;">
                                <tr>
                                    <td style="border:1px solid #1a4fa0; padding:6px 8px; color:#4b5563;">
                                        Monto del anticipo
                                    </td>
                                    <td style="border:1px solid #1a4fa0; padding:6px 8px; text-align:right; font-weight:600; color:#111827;">
                                        <span t-field="o.amount"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="border:1px solid #1a4fa0; padding:6px 8px; color:#4b5563;">
                                        Monto aplicado
                                    </td>
                                    <td style="border:1px solid #1a4fa0; padding:6px 8px; text-align:right; color:#111827;">
                                        <span t-field="o.amount_applied"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="border:1px solid #1a4fa0; padding:6px 8px; color:#4b5563; font-weight:600;">
                                        Saldo pendiente
                                    </td>
                                    <td style="border:1px solid #1a4fa0; padding:6px 8px; text-align:right; font-weight:700; color:#1a4fa0; font-size:12px;">
                                        <span t-field="o.amount_residual"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <div style="margin-top:18px; padding-top:8px; border-top:1px solid #e5e7eb; text-align:center; font-size:9px; color:#9ca3af;">
                    Documento generado por Kenocia Tesorería ·
                    <span t-out="o._get_advance_receipt_title()"/>
                </div>
            </div>
        </t>
    </template>

</odoo>
