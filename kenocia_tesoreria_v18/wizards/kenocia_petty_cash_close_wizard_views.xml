<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_petty_cash_close_wizard_form" model="ir.ui.view">
        <field name="name">kenocia.petty.cash.close.wizard.form</field>
        <field name="model">kenocia.petty.cash.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Cierre de Fondo de Caja Chica">
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <group string="Fondo a cerrar">
                        <field name="fund_id" readonly="1"/>
                    </group>
                    <group string="Arqueo final">
                        <group>
                            <field name="amount_system" readonly="1"
                                   string="Saldo según sistema"/>
                            <field name="amount_physical"
                                   string="Saldo físico contado"/>
                            <field name="amount_difference" readonly="1"
                                   string="Diferencia"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="journal_return_id"/>
                        </group>
                    </group>
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="amount_difference == 0">
                        Existe una diferencia entre el saldo del sistema y el conteo físico.
                        Verifique antes de confirmar.
                    </div>
                    <div class="alert alert-info mb-3" role="alert"
                         invisible="amount_system != 0">
                        El saldo disponible es cero. No se generará asiento de devolución.
                    </div>
                    <group string="Observaciones">
                        <field name="notes" nolabel="1"
                               placeholder="Notas del arqueo, observaciones, responsables presentes..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_close"
                            string="Confirmar cierre"
                            type="object"
                            class="btn-danger"
                            confirm="¿Confirma el cierre del fondo? Esta acción no se puede deshacer."
                            data-hotkey="v"/>
                    <button string="Cancelar"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
