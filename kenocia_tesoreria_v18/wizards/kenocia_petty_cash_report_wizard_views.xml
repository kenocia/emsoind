<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_petty_cash_report_wizard_form" model="ir.ui.view">
        <field name="name">kenocia.petty.cash.report.wizard.form</field>
        <field name="model">kenocia.petty.cash.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reportes Caja Chica">
                <group>
                    <group>
                        <field name="report_type"/>
                        <field name="output_format"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="state_filter"/>
                    </group>
                </group>
                <group>
                    <field name="fund_ids" widget="many2many_tags"
                           domain="[('company_id', '=', company_id)]"/>
                    <field name="custodian_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_print_report"
                            string="Generar reporte"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_petty_cash_report_wizard" model="ir.actions.act_window">
        <field name="name">Reportes Caja Chica</field>
        <field name="res_model">kenocia.petty.cash.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_kenocia_report_petty_cash"
              name="Caja Chica"
              parent="menu_tesoreria_reports"
              action="action_petty_cash_report_wizard"
              sequence="30"
              groups="kenocia_tesoreria_v18.group_tesoreria_supervisor,kenocia_tesoreria_v18.group_tesoreria_admin"/>

</odoo>
