<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_petty_cash_settlement_form" model="ir.ui.view">
        <field name="name">kenocia.petty.cash.settlement.form</field>
        <field name="model">kenocia.petty.cash.settlement</field>
        <field name="arch" type="xml">
            <form string="Liquidar Anticipo con Factura SAR">
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <field name="obligado_dmc" invisible="1"/>
                    <field name="fiscal_compliance_ok" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="tipo_contribuyente" invisible="1"/>

                    <group string="Anticipo a liquidar">
                        <group>
                            <field name="line_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="fund_id" readonly="1"/>
                            <field name="amount_advance" readonly="1"/>
                            <field name="settlement_date"/>
                        </group>
                    </group>

                    <separator/>

                    <group string="Paso 1 — Proveedor del documento fiscal">
                        <field name="partner_id"
                               options="{'no_create': True}"
                               placeholder="Buscar proveedor local o del extranjero..."/>
                        <field name="vendor_rtn" readonly="1"
                               invisible="not partner_id"/>
                        <field name="vendor_fiscal_label" readonly="1"
                               invisible="not partner_id"/>
                    </group>

                    <group string="Paso 2 — Factura SAR del proveedor"
                           invisible="not partner_id">
                        <field name="invoice_id"
                               options="{'no_create': True}"
                               placeholder="Seleccione la factura a liquidar..."
                               domain="[
                                   ('move_type', '=', 'in_invoice'),
                                   ('state', '=', 'posted'),
                                   ('payment_state', 'in', ['not_paid', 'partial']),
                                   ('partner_id', '=', partner_id),
                                   ('company_id', '=', company_id)
                               ]"/>
                        <field name="invoice_document_fiscal" readonly="1"
                               invisible="not invoice_id"/>
                        <field name="invoice_correlativo" readonly="1"
                               invisible="not invoice_id"/>
                        <field name="invoice_cai" readonly="1"
                               invisible="invoice_document_fiscal != 'vendors'"/>
                    </group>

                    <div class="alert alert-info mb-3" role="alert"
                         invisible="partner_id">
                        Seleccione primero el proveedor para ver sus facturas disponibles.
                    </div>

                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="not partner_id or invoice_id">
                        Seleccione la factura SAR correspondiente al gasto realizado.
                        Si no aparece, verifique que esté publicada y sin pagar
                        del proveedor seleccionado.
                    </div>

                    <group string="Paso 3 — Resumen de liquidación"
                           invisible="not invoice_id">
                        <group string="Factura">
                            <field name="amount_untaxed" readonly="1"/>
                            <field name="amount_tax" readonly="1"
                                   string="ISV (crédito fiscal)"/>
                            <field name="amount_invoice" readonly="1"
                                   string="Total factura"/>
                        </group>
                        <group string="Anticipo">
                            <field name="amount_advance" readonly="1"
                                   string="Anticipo entregado"/>
                            <field name="amount_diff" readonly="1"
                                   string="Vuelto al fondo"/>
                        </group>
                    </group>

                    <group string="Validación fiscal SAR"
                           invisible="not invoice_id">
                        <field name="fiscal_compliance_message" nolabel="1" colspan="2"/>
                        <field name="invoice_class_sar" readonly="1"
                               invisible="not obligado_dmc"/>
                        <field name="invoice_seccion_dmc" readonly="1"
                               invisible="not obligado_dmc"/>
                    </group>

                    <div class="alert alert-success mb-3" role="alert"
                         invisible="amount_diff &lt;= 0 or not invoice_id">
                        L.
                        <field name="amount_diff" readonly="1" nolabel="1"/>
                        regresarán automáticamente al saldo disponible del fondo.
                    </div>

                    <div class="alert alert-success mb-0" role="alert"
                         invisible="amount_diff != 0 or not invoice_id">
                        El anticipo cubre exactamente el total de la factura. Sin vuelto.
                    </div>
                </sheet>
                <footer>
                    <button name="action_confirm_settlement"
                            string="Confirmar liquidación"
                            type="object"
                            class="btn-primary"
                            invisible="not invoice_id"
                            confirm="¿Confirmar la liquidación del anticipo con esta factura?"
                            data-hotkey="v"/>
                    <button string="Cancelar"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
