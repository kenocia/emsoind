<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_apply_advance_wizard_form" model="ir.ui.view">
        <field name="name">kenocia.apply.advance.wizard.form</field>
        <field name="model">kenocia.apply.advance.wizard</field>
        <field name="arch" type="xml">
            <form string="Aplicar Adelantos">
                <group>
                    <field name="invoice_id" invisible="1"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="invoice_residual" readonly="1"/>
                </group>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="advance_id" readonly="1"/>
                        <field name="currency_id" column_invisible="True"/>
                        <field name="amount_available" readonly="1"/>
                        <field name="amount_to_apply"/>
                    </list>
                </field>
                <footer>
                    <button name="action_apply"
                            string="Aplicar"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
