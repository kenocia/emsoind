<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_payroll_dispersion_wizard_form" model="ir.ui.view">
        <field name="name">kenocia.payroll.dispersion.wizard.form</field>
        <field name="model">kenocia.payroll.dispersion.wizard</field>
        <field name="arch" type="xml">
            <form string="Dispersión de nómina">
                <group>
                    <group>
                        <field name="company_id" invisible="1"/>
                        <field name="payslip_run_id"/>
                        <field name="journal_id"/>
                    </group>
                    <group>
                        <field name="payment_date"/>
                        <field name="memo"/>
                        <field name="bank_format"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="employee_count"/>
                        <field name="amount_total"/>
                    </group>
                </group>
                <div class="text-muted">
                    Se generará un pago por empleado que salda su neto por pagar,
                    agrupados en un lote bancario. Las nóminas pasarán a "Pagado".
                </div>
                <footer>
                    <button name="action_confirm"
                            string="Generar dispersión de nómina"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kenocia_payroll_dispersion" model="ir.actions.act_window">
        <field name="name">Dispersión de nómina</field>
        <field name="res_model">kenocia.payroll.dispersion.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
