<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kenocia_void_wizard_form" model="ir.ui.view">
        <field name="name">kenocia.void.wizard.form</field>
        <field name="model">kenocia.void.wizard</field>
        <field name="arch" type="xml">
            <form string="Anular Cheque">
                <group>
                    <field name="payment_id" invisible="1"/>
                    <field name="payment_name" readonly="1"/>
                    <field name="void_reason"
                           placeholder="Indique el motivo de la anulación..."/>
                </group>
                <footer>
                    <button name="action_confirm_void"
                            string="Confirmar Anulación"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
