<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_generate_book_wizard_form" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.wizard.generate_book.form</field>
        <field name="model">kc_fiscal_hn.wizard.generate_book</field>
        <field name="arch" type="xml">
            <form string="Generar libro SAR desde facturas">
                <group>
                    <field name="book_type"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="date_from"
                           help="Primer día del mes calendario a declarar."/>
                    <field name="date_to"
                           help="Último día del mismo mes (se ajusta automáticamente)."/>
                    <field name="replace_existing"/>
                </group>
                <footer>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                    <button name="action_generar" type="object" string="Generar libro" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_generate_book_wizard" model="ir.actions.act_window">
        <field name="name">Generar libro SAR</field>
        <field name="res_model">kc_fiscal_hn.wizard.generate_book</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
