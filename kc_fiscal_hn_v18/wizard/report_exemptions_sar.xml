<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_report_exemptions_sar_form" model="ir.ui.view">
            <field name="name">kc_fiscal_hn.wizard.exemptions_sar.form</field>
            <field name="model">kc_fiscal_hn.wizard.exemptions_sar</field>
            <field name="arch" type="xml">
                <form string="Reporte de Exenciones y Exoneraciones SAR">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_download_excel"
                                    string="Descargar Excel"
                                    type="object"
                                    class="btn-secondary"
                         invisible="not excel_file"/>
                        </div>
                        <group>
                            <group string="Período">
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="company_id"/>
                                <field name="has_book_available"
                         invisible="1"/>
                            </group>
                            <group string="Filtros">
                                <field name="exemption_type"/>
                            </group>
                        </group>
                        <group string="Fuente de datos"
                         invisible="not has_book_available">
                            <field name="data_source" widget="radio"/>
                        </group>
                        <group string="Facturas en vivo"
                         invisible="data_source != 'live'">
                            <field name="live_document_state"/>
                        </group>
                        <group string="Libro SAR / Declaración"
                         invisible="(data_source != 'book' or not has_book_available)">
                            <field name="book_period_label"
                         readonly="1"/>
                            <field name="book_state_display"
                         readonly="1"/>
                            <field name="book_declaration_date"
                         readonly="1"/>
                            <field name="book_declared_by"
                         readonly="1"/>
                        </group>
                        <group string="Facturas en vivo"
                         invisible="bool(has_book_available)">
                            <field name="data_source"
                         invisible="1"/>
                            <field name="live_document_state"/>
                        </group>
                        <group string="Resultados"
                         invisible="not excel_file">
                            <group>
                                <field name="total_invoices"/>
                                <field name="total_exempt"/>
                            </group>
                            <group>
                                <field name="total_exonerated"/>
                            </group>
                        </group>
                        <group string="Archivo Generado"
                         invisible="not excel_file">
                            <field name="excel_filename"
                         readonly="1"/>
                            <field name="excel_file" filename="excel_filename"
                         readonly="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_generate_report"
                                string="Imprimir Reporte"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cerrar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_report_exemptions_sar" model="ir.actions.act_window">
            <field name="name">Reporte de Exenciones SAR</field>
            <field name="res_model">kc_fiscal_hn.wizard.exemptions_sar</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="view_report_exemptions_sar_form"/>
        </record>

        <record id="view_report_exemptions_sar_excel_form" model="ir.ui.view">
            <field name="name">kc_fiscal_hn.exemptions_sar.excel.form</field>
            <field name="model">kc_fiscal_hn.exemptions_sar.excel</field>
            <field name="arch" type="xml">
                <form string="Reporte de Exenciones SAR - Excel">
                    <sheet>
                        <group>
                            <field name="file_name"
                         readonly="1"/>
                            <field name="excel_file" filename="file_name"
                         readonly="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Cerrar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
