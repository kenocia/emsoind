<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_preregistro_cai_wizard_form" model="ir.ui.view">
            <field name="name">kc_fiscal_hn.wizard.preregistro_cai.form</field>
            <field name="model">kc_fiscal_hn.wizard.preregistro_cai</field>
            <field name="arch" type="xml">
                <form string="Preregistro CAI SAR" class="o_preregistro_cai_wizard">
                    <field name="paso_actual" invisible="1"/>
                    <field name="bloquear_secuencia" invisible="1"/>
                    <field name="paso_1_label" invisible="1"/>
                    <field name="paso_2_label" invisible="1"/>
                    <field name="paso_3_label" invisible="1"/>
                    <field name="puede_confirmar" invisible="1"/>
                    <field name="validacion_cai_ok" invisible="1"/>
                    <field name="validacion_rango_ok" invisible="1"/>
                    <field name="validacion_fecha_ok" invisible="1"/>
                    <field name="estado_actual" invisible="1"/>
                    <field name="currency_id" invisible="1"/>

                    <div class="oe_title mb-2">
                        <h2 class="mb-0">
                            <span
                         invisible="not bloquear_secuencia">
                                Agregar rango CAI
                            </span>
                            <span
                         invisible="bool(bloquear_secuencia)">
                                Preregistro de Numeración CAI
                            </span>
                        </h2>
                    </div>

                    <!-- Stepper -->
                    <div class="o_preregistro_stepper text-center">
                        <span class="badge rounded-pill text-bg-primary"
                         invisible="paso_actual != 1">
                            1. <field name="paso_1_label" nolabel="1" class="oe_inline"
                         readonly="1"/>
                        </span>
                        <span class="badge rounded-pill text-bg-secondary"
                         invisible="paso_actual == 1">
                            1. <field name="paso_1_label" nolabel="1" class="oe_inline"
                         readonly="1"/>
                        </span>
                        <span class="badge rounded-pill text-bg-primary"
                         invisible="paso_actual != 2">
                            2. <field name="paso_2_label" nolabel="1" class="oe_inline"
                         readonly="1"/>
                        </span>
                        <span class="badge rounded-pill text-bg-secondary"
                         invisible="paso_actual == 2">
                            2. <field name="paso_2_label" nolabel="1" class="oe_inline"
                         readonly="1"/>
                        </span>
                        <span class="badge rounded-pill text-bg-primary"
                         invisible="paso_actual != 3">
                            3. <field name="paso_3_label" nolabel="1" class="oe_inline"
                         readonly="1"/>
                        </span>
                        <span class="badge rounded-pill text-bg-secondary"
                         invisible="paso_actual == 3">
                            3. <field name="paso_3_label" nolabel="1" class="oe_inline"
                         readonly="1"/>
                        </span>
                    </div>

                    <sheet>
                        <!-- PASO 1 -->
                        <div class="o_preregistro_section"
                         invisible="paso_actual != 1">
                            <separator string="Paso 1 — Encabezado"
                                       invisible="not bloquear_secuencia"/>
                            <separator string="Paso 1 — Seleccionar secuencia fiscal"
                                       invisible="bloquear_secuencia"/>
                            <group
                         invisible="bool(bloquear_secuencia)">
                                <field name="sequence_id"
                                       options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group
                         invisible="not bloquear_secuencia">
                                <field name="sequence_id"
                                      
                                       string="Secuencia fiscal"
                         readonly="1"/>
                            </group>
                        </div>

                        <!-- Estado actual: solo paso 1 -->
                        <div
                             class="o_preregistro_section"
                         invisible="(not sequence_id or paso_actual != 1)">
                            <separator string="Estado actual del CAI"/>

                            <div class="alert alert-success mb-3"
                                 role="alert"
                         invisible="estado_actual != 'active'">
                                <strong>Estado: Activo y saludable</strong>
                            </div>
                            <div class="alert alert-warning mb-3"
                                 role="alert"
                         invisible="estado_actual != 'warning'">
                                <strong>Estado: Próximo a vencer o agotarse</strong>
                            </div>
                            <div class="alert alert-danger mb-3"
                                 role="alert"
                         invisible="estado_actual not in ('critical', 'expired')">
                                <strong>Estado: Crítico o agotado</strong>
                            </div>
                            <div class="alert alert-secondary mb-3"
                                 role="alert"
                         invisible="estado_actual != 'sin_rango'">
                                <strong>Sin rango CAI activo</strong>
                            </div>

                            <group col="2">
                                <group string="CAI vigente">
                                    <field name="rango_actual_cai"
                                          
                                           string="CAI"
                                           class="o_preregistro_cai_value"
                         readonly="1"/>
                                    <field name="rango_actual_desde"
                                          
                                           string="Válido desde"
                         readonly="1"/>
                                    <field name="rango_actual_hasta"
                                          
                                           string="Válido hasta"
                         readonly="1"/>
                                </group>
                                <group string="Uso del rango">
                                    <field name="rango_actual_inicial"
                                          
                                           string="Correlativo inicial"
                         readonly="1"/>
                                    <field name="rango_actual_final"
                                          
                                           string="Correlativo final"
                         readonly="1"/>
                                    <field name="rango_actual_siguiente"
                                          
                                           string="Siguiente número"
                         readonly="1"/>
                                    <field name="rango_actual_disponibles"
                                          
                                           string="Disponibles"
                         readonly="1"/>
                                    <field name="rango_actual_total"
                                          
                                           string="Total del rango"
                         readonly="1"/>
                                    <field name="rango_actual_porcentaje"
                                          
                                           string="Porcentaje usado (%)"
                                           widget="float"
                                           digits="[16, 1]"
                         readonly="1"/>
                                    <field name="rango_actual_dias"
                                          
                                           string="Días restantes"
                         readonly="1"/>
                                </group>
                            </group>
                        </div>

                        <!-- Resumen compacto pasos 2 y 3 -->
                        <div
                             class="alert alert-light o_preregistro_compact"
                             role="status"
                         invisible="(not sequence_id or paso_actual == 1)">
                            <strong>Secuencia:</strong>
                            <field name="sequence_id"
                                  
                                   nolabel="1"
                                   class="oe_inline"
                         readonly="1"/>
                            <span class="mx-2">|</span>
                            <strong>CAI actual:</strong>
                            <field name="rango_actual_cai"
                                  
                                   nolabel="1"
                                   class="oe_inline o_preregistro_cai_value"
                         readonly="1"/>
                            <span class="mx-2">|</span>
                            <strong>Disponibles:</strong>
                            <field name="rango_actual_disponibles"
                                  
                                   nolabel="1"
                                   class="oe_inline"
                         readonly="1"/>
                        </div>

                        <!-- PASO 2 -->
                        <div class="o_preregistro_section"
                         invisible="paso_actual != 2">
                            <separator string="Paso 2 — Detalle del nuevo CAI"
                                       invisible="not bloquear_secuencia"/>
                            <separator string="Paso 2 — Datos del nuevo CAI"
                                       invisible="bloquear_secuencia"/>

                            <group col="2">
                                <group string="Identificación y vigencia">
                                    <field name="nuevo_cai"
                                           placeholder="Ingrese el CAI autorizado por SAR"/>
                                    <div class="o_preregistro_field_hint text-success"
                         invisible="(not validacion_cai_ok or not nuevo_cai)">
                                        ✓ Formato de CAI correcto
                                    </div>
                                    <div class="o_preregistro_field_hint text-danger"
                         invisible="(bool(validacion_cai_ok) or not nuevo_cai)">
                                        ✗ Mínimo 10 caracteres
                                    </div>
                                    <field name="nuevo_desde" string="Válido desde"/>
                                    <field name="nuevo_hasta" string="Fecha límite emisión"/>
                                </group>
                                <group string="Rango numérico">
                                    <field name="nuevo_rango_inicial"/>
                                    <field name="nuevo_rango_final"/>
                                    <field name="activacion"/>
                                </group>
                            </group>

                            <separator string="Vista previa automática"/>
                            <group col="2">
                                <field name="preview_primer_correlativo"
                                      
                                       string="Primer correlativo"
                         readonly="1"/>
                                <field name="preview_ultimo_correlativo"
                                      
                                       string="Último correlativo"
                         readonly="1"/>
                                <field name="preview_total_disponibles"
                                      
                                       string="Total disponibles"
                         readonly="1"/>
                            </group>
                        </div>

                        <!-- PASO 3 -->
                        <div class="o_preregistro_section"
                         invisible="paso_actual != 3">
                            <separator string="Paso 3 — Validaciones y confirmación"/>

                            <group string="Validaciones en tiempo real">
                                <field name="validacion_mensaje"
                                       nolabel="1"
                                      
                                       widget="text"
                         readonly="1"/>
                            </group>

                            <group string="Resumen del preregistro" col="2">
                                <field name="sequence_id"
                         readonly="1"/>
                                <field name="nuevo_cai"
                         readonly="1"/>
                                <field name="nuevo_desde"
                         readonly="1"/>
                                <field name="nuevo_hasta"
                         readonly="1"/>
                                <field name="nuevo_rango_inicial"
                         readonly="1"/>
                                <field name="nuevo_rango_final"
                         readonly="1"/>
                            </group>

                            <separator string="Preview del resultado"/>
                            <div class="alert alert-info o_preregistro_preview_box" role="alert">
                                <p>
                                    El primer correlativo será:
                                    <strong>
                                        <field name="preview_primer_correlativo"
                                              
                                               nolabel="1"
                                               class="oe_inline"
                         readonly="1"/>
                                    </strong>
                                </p>
                                <p>
                                    El último correlativo será:
                                    <strong>
                                        <field name="preview_ultimo_correlativo"
                                              
                                               nolabel="1"
                                               class="oe_inline"
                         readonly="1"/>
                                    </strong>
                                </p>
                                <p class="mb-0">
                                    Total disponibles:
                                    <strong>
                                        <field name="preview_total_disponibles"
                                              
                                               nolabel="1"
                                               class="oe_inline"
                         readonly="1"/>
                                    </strong>
                                </p>
                            </div>
                        </div>
                    </sheet>

                    <footer>
                        <button name="action_paso_anterior"
                                string="← Anterior"
                                type="object"
                                class="btn-secondary"
                         invisible="paso_actual == 1"/>
                        <button name="action_paso_siguiente"
                                string="Siguiente →"
                                type="object"
                                class="btn-primary"
                         invisible="paso_actual == 3"/>
                        <button name="action_confirmar_preregistro"
                                string="Confirmar preregistro"
                                type="object"
                                class="btn-success"
                         invisible="(paso_actual != 3 or not puede_confirmar)"/>
                        <button string="Corrija las validaciones"
                                class="btn-secondary"
                               
                                disabled="1"
                         invisible="(paso_actual != 3 or bool(puede_confirmar))"/>
                        <button string="Cancelar" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_preregistro_cai" model="ir.actions.act_window">
            <field name="name">Preregistro CAI</field>
            <field name="res_model">kc_fiscal_hn.wizard.preregistro_cai</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="view_preregistro_cai_wizard_form"/>
            <field name="context">{'dialog_size': 'large'}</field>
        </record>

    </data>
</odoo>
