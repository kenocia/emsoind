<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_fiscal_sequence_manager"
            model="res.groups">
        <field name="name">
            Administrador de Numeración Fiscal
        </field>
        <field name="category_id"
               ref="base.module_category_accounting"/>
        <field name="implied_ids"
               eval="[(4, ref('account.group_account_manager'))]"/>
        <field name="comment">
            Puede cancelar y eliminar facturas fiscales SAR.
            Solo para administradores con acceso al SAR.
        </field>
    </record>

    <record id="group_zoli_gerencia"
            model="res.groups">
        <field name="name">
            Gerencia de Zona Libre (ZOLI)
        </field>
        <field name="category_id"
               ref="base.module_category_accounting"/>
        <field name="implied_ids"
               eval="[(4, ref('stock.group_stock_manager'))]"/>
        <field name="comment">
            Puede autorizar expresamente el uso de lotes DUCA vencidos y
            gestionar los controles del régimen de Zona Libre.
        </field>
    </record>
</odoo>
