<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_picking_type_form_extended" model="ir.ui.view">
        <field name="name">stock.picking.type.form</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='create_backorder']" position="after">
                <field name="sequence_sar_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_picking_form_inherited" model="ir.ui.view">
        <field name="name">stock.picking.form.inherited</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='do_print_picking']" position="attributes">
                <attribute name="invisible">state != 'assigned' or picking_type_code == 'outgoing'</attribute>
            </xpath>
            <xpath expr="//header/button[@type='action'][@data-hotkey='o'][@groups='base.group_user']" position="attributes">
                <attribute name="invisible">state != 'done' or picking_type_code == 'outgoing'</attribute>
            </xpath>
            <xpath expr="//button[@name='do_print_picking']" position="after">
                <button name="action_print_salida_inventario"
                        type="object"
                        string="Imprimir"
                        groups="base.group_user"
                        invisible="picking_type_code != 'outgoing' or state not in ('assigned', 'done')"
                        data-hotkey="o"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="update_custom_fields"
                        type="object"
                        string="Actualizar Numeración SAR"
                        class="oe_highlight"
                        icon="fa-refresh"/>
            </xpath>
            <xpath expr="//sheet/notebook/page[@name='extra']" position="after">
                <page name="saar" string="SAR">
                    <group>
                        <group string="Información SAR" name="info_sar">
                            <field name="sar_name"
                         readonly="1"/>
                            <field name="cai"
                         readonly="1"/>
                            <field name="numeroInicial"
                         readonly="1"/>
                            <field name="numeroFinal"
                         readonly="1"/>
                            <field name="motivo_traslado"/>
                        </group>
                        <group string="Datos del Transportista" name="info_transport">
                            <field name="transporter_name"/>
                            <field name="transporter_rtn"/>
                            <field name="vehicle_info"/>
                            <field name="driver_license"/>
                            <field name="fechaLimiteEmision"
                         readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>