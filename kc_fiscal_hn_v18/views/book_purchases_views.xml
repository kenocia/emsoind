<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_book_purchases_header_list" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.book.purchases.header.list</field>
        <field name="model">kc_fiscal_hn.book.purchases</field>
        <field name="arch" type="xml">
            <list string="Libros de Compras SAR (DMC)">
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="modo_dmc"
                         column_invisible="True"/>
                <field name="nivel_control" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'declared'"
                       decoration-danger="state == 'rectified'"/>
                <field name="alerta_vencimiento" widget="badge" optional="show"
                       decoration-danger="alerta_vencimiento == 'vencido'"
                       decoration-warning="alerta_vencimiento in ('urgente', 'proximo')"/>
                <field name="total_compras" sum="Total"/>
                <field name="total_nc_recibidas" sum="Total"/>
                <field name="total_nd_recibidas" sum="Total"/>
                <field name="credito_fiscal_total" sum="Total" optional="show"/>
                <field name="total_general" sum="Total"/>
                <field name="fecha_vencimiento_dmc" optional="hide"/>
                <field name="fecha_declaracion" optional="show"/>
                <field name="declarado_por" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_book_purchases_form" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.book.purchases.form</field>
        <field name="model">kc_fiscal_hn.book.purchases</field>
        <field name="arch" type="xml">
            <form string="Libro de Compras SAR">
                <header>
                    <div class="alert alert-danger mb-0 w-100"
                         invisible="alerta_vencimiento != 'vencido'">
                        <strong>DMC VENCIDA</strong> —
                        Fecha límite:
                        <field name="fecha_vencimiento_dmc"
                               nolabel="1"
                         readonly="1"/>
                        — Presente inmediatamente en el SAR.
                    </div>
                    <div class="alert alert-danger mb-0 w-100"
                         invisible="alerta_vencimiento != 'urgente'">
                        <strong>DMC vence en
                        <field name="dias_para_vencer"
                               nolabel="1"
                         readonly="1"/>
                        días</strong> —
                        <field name="fecha_vencimiento_dmc"
                               nolabel="1"
                         readonly="1"/>
                    </div>
                    <div class="alert alert-warning mb-0 w-100"
                         invisible="alerta_vencimiento != 'proximo'">
                        DMC vence el
                        <field name="fecha_vencimiento_dmc"
                               nolabel="1"
                         readonly="1"/>
                        (primeros 8 días hábiles del mes siguiente)
                    </div>
                    <button name="action_generate"
                            string="Generar Libro"
                            type="object"
                            class="btn-primary"
                         invisible="state == 'declared'"/>
                    <button name="action_declare"
                            string="Marcar Declarado"
                            type="object"
                            class="btn-success"
                         invisible="state != 'pending'"/>
                    <button name="action_rectify"
                            string="Rectificar"
                            type="object"
                            class="btn-warning"
                         invisible="state != 'declared'"/>
                    <button name="action_export_excel"
                            string="Exportar Excel"
                            type="object"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,declared,rectified"/>
                    <field name="modo_dmc"
                         invisible="1"/>
                    <field name="alerta_vencimiento"
                         invisible="1"/>
                </header>
                <sheet>
                    <div class="alert alert-info mb-3" role="alert"
                         invisible="state != 'draft'">
                        <strong
                         invisible="not modo_dmc">
                            Libro de Compras DMC
                            (Mediano/Grande Contribuyente)
                        </strong>
                        <strong
                         invisible="bool(modo_dmc)">
                            Libro de Compras
                            (Pequeño Contribuyente)
                        </strong>
                        <ol class="mb-0 mt-2 small">
                            <li>Configure el período (Fecha Desde / Hasta)</li>
                            <li>Clic en <strong>Generar Libro</strong> para cargar compras</li>
                            <li>Revise y ajuste líneas si es necesario</li>
                            <li
                         invisible="not modo_dmc">
                                Complete importaciones si aplica (Sección C)
                            </li>
                            <li>Clic en <strong>Marcar Declarado</strong> cuando envíe al SAR</li>
                            <li>Exporte a Excel como respaldo</li>
                        </ol>
                    </div>
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="state != 'pending'">
                        <strong>Pendiente de declarar.</strong>
                        Revise las líneas y presione
                        <strong>Marcar Declarado</strong>.
                        <span
                         invisible="not modo_dmc">
                            <br/>Presente en el SAR antes del
                            <field name="fecha_vencimiento_dmc"
                                   nolabel="1"
                         readonly="1"/>.
                        </span>
                    </div>
                    <div class="alert alert-success mb-3" role="alert"
                         invisible="state != 'declared'">
                        <strong>Declarado al SAR</strong>
                        por <field name="declarado_por" nolabel="1"
                         readonly="1"/>
                        el <field name="fecha_declaracion" nolabel="1"
                         readonly="1"/>.
                        Este libro está bloqueado.
                    </div>

                    <div class="row mb-3">
                        <div class="col-8">
                            <h2>
                                <field name="name" nolabel="1"
                         readonly="1"/>
                            </h2>
                            <span class="badge text-bg-info me-2">
                                <field name="nivel_control"
                                       nolabel="1"
                         readonly="1"/>
                            </span>
                            <span class="badge text-bg-danger"
                         invisible="not modo_dmc">
                                Obligado DMC
                            </span>
                            <span class="badge text-bg-dark ms-1"
                         invisible="not es_agente_retencion">
                                Agente Retención
                            </span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-lg-6">
                            <group string="Período">
                                <field name="date_from"
                                      
                                       help="Primer día del mes calendario a declarar."
                         readonly="state == 'declared'"/>
                                <field name="date_to"
                                      
                                       help="Último día del mismo mes (se ajusta automáticamente)."
                         readonly="state == 'declared'"/>
                                <field name="company_id"
                                       groups="base.group_multi_company"
                         readonly="state == 'declared'"/>
                                <field name="currency_id"
                         invisible="1"/>
                            </group>
                        </div>
                        <div class="col-lg-6">
                            <group string="Declaración">
                                <field name="fecha_declaracion"
                         readonly="1"/>
                                <field name="declarado_por"
                         readonly="1"/>
                                <field name="fecha_vencimiento_dmc"
                         invisible="not modo_dmc"
                         readonly="1"/>
                                <field name="dias_para_vencer"
                         invisible="not modo_dmc"
                         readonly="1"/>
                            </group>
                        </div>
                    </div>

                    <group string="Totales del Libro">
                        <group>
                            <field name="total_compras"
                         readonly="1"/>
                            <field name="total_nc_recibidas"
                         readonly="1"/>
                            <field name="total_nd_recibidas"
                         readonly="1"/>
                        </group>
                        <group>
                            <field name="total_isv_credito"
                                  
                                   class="fw-bold text-success"
                         readonly="1"/>
                            <field name="total_general"
                                  
                                   class="fw-bold"
                         readonly="1"/>
                        </group>
                    </group>

                    <div
                         invisible="not modo_dmc">
                        <group string="Sección A — Compras Locales">
                            <group>
                                <field name="total_fa_gravadas_15"
                         readonly="1"/>
                                <field name="total_fa_gravadas_18"
                         readonly="1"/>
                                <field name="total_oc_gravadas"
                         readonly="1"/>
                            </group>
                            <group>
                                <field name="total_exentas"
                         readonly="1"/>
                                <field name="total_exoneradas"
                         readonly="1"/>
                            </group>
                        </group>
                        <group string="Sección B — Comprobantes Eventuales"
                         invisible="not modo_dmc">
                            <group>
                                <field name="total_seccion_b"
                         readonly="1"/>
                                <field name="total_boletas_compra"
                         readonly="1"/>
                            </group>
                            <group>
                                <div class="alert alert-info small py-1 mb-0">
                                    <strong>Sección B incluye:</strong><br/>
                                    Boletas de compra, compras a personas
                                    naturales sin RTN, proveedores ocasionales
                                    y otros comprobantes eventuales.
                                </div>
                            </group>
                        </group>
                        <group string="Sección C — Importaciones">
                            <group>
                                <field name="total_importaciones_15"
                         readonly="state == 'declared'"/>
                                <field name="total_importaciones_18"
                         readonly="state == 'declared'"/>
                                <field name="total_importaciones_exentas"
                         readonly="state == 'declared'"/>
                            </group>
                            <group>
                                <field name="total_fyduca"
                         readonly="state == 'declared'"/>
                                <field name="credito_fiscal_total"
                                      
                                       class="fw-bold text-success"
                         readonly="1"/>
                            </group>
                        </group>
                    </div>

                    <group string="Verificación ISV vs DMC"
                         invisible="not modo_dmc">
                        <group>
                            <field name="credito_fiscal_total"
                                  
                                   class="fw-bold text-success"
                         readonly="1"/>
                            <field name="credito_declarado_isv"/>
                        </group>
                        <group>
                            <field name="diferencia_isv_dmc"
                         invisible="not credito_declarado_isv"
                         readonly="1"/>
                            <field name="consistencia_isv"
                                  
                                   widget="badge"
                                  
                                   decoration-success="consistencia_isv == 'ok'"
                                   decoration-warning="consistencia_isv == 'diferencia'"
                                   decoration-muted="consistencia_isv == 'sin_verificar'"
                         invisible="not credito_declarado_isv"
                         readonly="1"/>
                        </group>
                    </group>
                    <div
                         invisible="not modo_dmc">
                        <div class="alert alert-danger mb-3"
                         invisible="consistencia_isv != 'diferencia'">
                            <strong>Diferencia detectada.</strong>
                            El SAR cruza estos valores automáticamente.
                            Una diferencia puede generar un requerimiento
                            de información o auditoría. Verifique antes de declarar.
                        </div>
                        <div class="alert alert-success mb-3"
                         invisible="consistencia_isv != 'ok'">
                            <strong>Valores consistentes.</strong>
                            El crédito fiscal de la DMC coincide
                            con la Declaración ISV.
                        </div>
                    </div>

                    <notebook>
                        <page name="lineas" string="Líneas del Libro">
                            <field name="line_ids"
                         readonly="1">
                                <list create="0" delete="0"
                                      decoration-info=
                                      "tipo_documento == 'nota_credito'"
                                      decoration-warning=
                                      "tipo_documento == 'nota_debito'">
                                    <field name="tipo_documento" widget="badge"/>
                                    <field name="seccion_dmc"
                                           widget="badge"
                                           optional="show"
                                          
                                           decoration-success="seccion_dmc == 'A'"
                                           decoration-warning="seccion_dmc == 'B'"
                                           decoration-info="seccion_dmc == 'C'"
                         readonly="1"
                         column_invisible="not parent.modo_dmc"/>
                                    <field name="tipo_compra_dmc"
                                           widget="badge"
                                           optional="hide"
                         readonly="1"
                         column_invisible="not parent.modo_dmc"/>
                                    <field name="numero_dua"
                                           optional="hide"
                         readonly="1"
                         column_invisible="not parent.modo_dmc"/>
                                    <field name="fecha"
                         readonly="1"/>
                                    <field name="rtn_proveedor"
                         readonly="1"/>
                                    <field name="proveedor"
                         readonly="1"/>
                                    <field name="clase_documento"
                                           optional="show"
                                          
                                           column_invisible=
                                           "parent.modo_dmc == False"
                         readonly="1"/>
                                    <field name="cai_proveedor"
                                           optional="show"
                                          
                                           column_invisible=
                                           "parent.modo_dmc == False"
                         readonly="1"/>
                                    <field name="numero_factura"
                         readonly="1"/>
                                    <field name="fecha_emision"
                                           optional="hide"
                                          
                                           column_invisible=
                                           "parent.modo_dmc == False"
                         readonly="1"/>
                                    <field name="exento" sum="Total"
                         readonly="1"/>
                                    <field name="exonerado" sum="Total"
                         readonly="1"/>
                                    <field name="gravado_15" sum="Total"
                         readonly="1"/>
                                    <field name="isv_15" sum="Total"
                         readonly="1"/>
                                    <field name="gravado_18" sum="Total"
                         readonly="1"/>
                                    <field name="isv_18" sum="Total"
                         readonly="1"/>
                                    <field name="costo" sum="Total"
                                           optional="show"
                                          
                                           column_invisible=
                                           "parent.modo_dmc == False"
                         readonly="1"/>
                                    <field name="gasto" sum="Total"
                                           optional="show"
                                          
                                           column_invisible=
                                           "parent.modo_dmc == False"
                         readonly="1"/>
                                    <field name="no_deducible" sum="Total"
                                           optional="hide"
                                          
                                           column_invisible=
                                           "parent.modo_dmc == False"
                         readonly="1"/>
                                    <field name="amount_total" sum="Total"
                         readonly="1"/>
                                    <field name="invoice_id" optional="hide"/>
                                    <field name="currency_id"
                         column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page name="notas"
                              string="Notas de Rectificación"
                         invisible="state not in ('rectified', 'declared')">
                            <field name="notas_rectificacion"
                                  
                                   placeholder="Describa los cambios y el motivo de la rectificación..."
                         readonly="state == 'rectified'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_book_purchases_search" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.book.purchases.search</field>
        <field name="model">kc_fiscal_hn.book.purchases</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <filter string="Borrador" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Pendiente" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Declarado" name="declared" domain="[('state','=','declared')]"/>
                <filter string="DMC vencida" name="vencida"
                        domain="[('alerta_vencimiento','=','vencido')]"/>
                <filter string="Modo DMC" name="modo_dmc" domain="[('modo_dmc','=',True)]"/>
                <separator/>
                <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Mes" name="group_month" context="{'group_by': 'date_from:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_book_purchases" model="ir.actions.act_window">
        <field name="name">Libro de Compras (DMC)</field>
        <field name="res_model">kc_fiscal_hn.book.purchases</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_book_purchases_search"/>
    </record>

</odoo>
