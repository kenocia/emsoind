<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_tax_by_codigo_sar" model="ir.actions.act_window">
        <field name="name">Impuestos vinculados</field>
        <field name="res_model">account.tax</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('codigo_sar_id', '=', active_id)]</field>
    </record>

    <record id="view_codigo_sar_list" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.codigo.sar.list</field>
        <field name="model">kc_fiscal_hn.codigo.sar</field>
        <field name="arch" type="xml">
            <list string="Códigos SAR Honduras"
                  decoration-muted="not activo">
                <field name="codigo"/>
                <field name="nombre"/>
                <field name="tipo_impuesto"/>
                <field name="tipo_uso"/>
                <field name="porcentaje"/>
                <field name="activo" widget="boolean_toggle"/>
                <field name="tax_count" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_codigo_sar_form" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.codigo.sar.form</field>
        <field name="model">kc_fiscal_hn.codigo.sar</field>
        <field name="arch" type="xml">
            <form string="Código SAR Honduras">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_tax_by_codigo_sar)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-percent">
                            <field name="tax_count"
                                   widget="statinfo"
                                   string="Impuestos"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="codigo"/>
                        <h1>
                            <field name="codigo" placeholder="01"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="tipo_impuesto"/>
                            <field name="tipo_uso"/>
                            <field name="porcentaje"/>
                            <field name="activo"/>
                        </group>
                        <group>
                            <field name="base_legal"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1"
                               placeholder="Descripción normativa del código SAR..."/>
                    </group>
                    <notebook>
                        <page string="Impuestos vinculados" name="taxes">
                            <field name="tax_ids"
                         readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="type_tax_use"/>
                                    <field name="amount"/>
                                    <field name="company_id"
                                           groups="base.group_multi_company"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_codigo_sar_search" model="ir.ui.view">
        <field name="name">kc_fiscal_hn.codigo.sar.search</field>
        <field name="model">kc_fiscal_hn.codigo.sar</field>
        <field name="arch" type="xml">
            <search string="Códigos SAR">
                <field name="codigo"/>
                <field name="nombre"/>
                <field name="tipo_impuesto"/>
                <filter string="Activos" name="activos"
                        domain="[('activo', '=', True)]"/>
                <filter string="Inactivos" name="inactivos"
                        domain="[('activo', '=', False)]"/>
                <separator/>
                <filter string="ISV" name="isv"
                        domain="[('tipo_impuesto', '=', 'isv')]"/>
                <filter string="Retención" name="retencion"
                        domain="[('tipo_impuesto', '=', 'retencion')]"/>
                <filter string="Exento" name="exento"
                        domain="[('tipo_impuesto', '=', 'exento')]"/>
                <filter string="Exonerado" name="exonerado"
                        domain="[('tipo_impuesto', '=', 'exonerado')]"/>
                <group>
                    <filter string="Tipo de Impuesto"
                            name="group_tipo_impuesto"
                            context="{'group_by': 'tipo_impuesto'}"/>
                    <filter string="Uso"
                            name="group_tipo_uso"
                            context="{'group_by': 'tipo_uso'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_codigo_sar" model="ir.actions.act_window">
        <field name="name">Códigos SAR Honduras</field>
        <field name="res_model">kc_fiscal_hn.codigo.sar</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_codigo_sar_search"/>
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tabla maestra de códigos SAR Honduras
            </p>
            <p>
                Configure los códigos oficiales del SAR y vincúlelos
                a los impuestos de Odoo para reportes fiscales.
            </p>
        </field>
    </record>

</odoo>
