    <record id="journal_purchases_fa_hn" model="account.journal">
        <field name="name">Compras Nacionales (FA)</field>
        <field name="code">CFA</field>
        <field name="type">purchase</field>
        <field name="document_fiscal">vendors</field>
        <field name="company_id" eval="ref('base.main_company')"/>
        <field name="sequence" eval="10"/>
    </record>

    <record id="journal_boleta_compra_hn" model="account.journal">
        <field name="name">Boletas de Compra</field>
        <field name="code">BOL</field>
        <field name="type">purchase</field>
        <field name="document_fiscal">boleta</field>
        <field name="fiscal_sequence_id" ref="sequence_fiscal_boleta"/>
        <field name="company_id" eval="ref('base.main_company')"/>
        <field name="sequence" eval="11"/>
    </record>

    <record id="journal_compras_extranjera_hn" model="account.journal">
        <field name="name">Compras Extranjera (FE)</field>
        <field name="code">CFE</field>
        <field name="type">purchase</field>
        <field name="document_fiscal">extranjera</field>
        <field name="company_id" eval="ref('base.main_company')"/>
        <field name="sequence" eval="12"/>
    </record>

    <record id="journal_importaciones_hn" model="account.journal">
        <field name="name">Importaciones (DUA/FYDUCA)</field>
        <field name="code">IMP</field>
        <field name="type">purchase</field>
        <field name="document_fiscal">importacion</field>
        <field name="company_id" eval="ref('base.main_company')"/>
        <field name="sequence" eval="13"/>
    </record>

    <record id="journal_retencion_hn" model="account.journal">
        <field name="name">Comprobantes de Retención</field>
        <field name="code">RET</field>
        <field name="type">purchase</field>
        <field name="document_fiscal">retention</field>
        <field name="fiscal_sequence_id" ref="sequence_fiscal_retencion"/>
        <field name="company_id" eval="ref('base.main_company')"/>
        <field name="sequence" eval="13"/>
    </record>

    <record id="journal_nc_proveedores_hn" model="account.journal">
        <field name="name">Notas de Crédito Proveedores</field>
        <field name="code">NCP</field>
        <field name="type">purchase</field>
        <field name="document_fiscal">credit</field>
        <field name="company_id" eval="ref('base.main_company')"/>
        <field name="sequence" eval="14"/>
    </record>

    <!-- ════════════════════════════════════
         SECUENCIAS DE REFERENCIA DE CONTACTOS
         (no fiscales; correlativo por tipo)
         ════════════════════════════════════ -->

    <record id="seq_partner_contac" model="ir.sequence">
        <field name="name">Referencia Contacto — Persona</field>
        <field name="code">kc_fiscal_hn.partner.contac</field>
        <field name="prefix">CONTAC-</field>
        <field name="padding">4</field>
        <field name="implementation">no_gap</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_partner_empnac" model="ir.sequence">
        <field name="name">Referencia Contacto — Empresa Nacional</field>
        <field name="code">kc_fiscal_hn.partner.empnac</field>
        <field name="prefix">EMPNAC</field>
        <field name="padding">4</field>
        <field name="implementation">no_gap</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_partner_empext" model="ir.sequence">
        <field name="name">Referencia Contacto — Empresa Extranjera</field>
        <field name="code">kc_fiscal_hn.partner.empext</field>
        <field name="prefix">EMPEXT</field>
        <field name="padding">4</field>
        <field name="implementation">no_gap</field>
        <field name="company_id" eval="False"/>
    </record>

    </data>

    <data noupdate="0">
        <record id="cron_activar_rango_cai" model="ir.cron">
            <field name="name">Activar Rango CAI Fiscal HN</field>
            <field name="model_id" ref="base.model_ir_sequence"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_activar_siguiente_rango()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="nextcall" eval="
                (DateTime.now() + timedelta(days=1)).replace(
                    hour=6, minute=0, second=0
                ).strftime('%Y-%m-%d %H:%M:%S')
            "/>
        </record>
        <record id="cron_alertas_constancias" model="ir.cron">
            <field name="name">Alertas Constancias Pago a Cuenta SAR</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_verificar_constancias()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
        <record id="cron_alertas_exoneracion" model="ir.cron">
            <field name="name">Alertas Vencimiento Exoneración SAR</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_alertas_exoneracion()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
        <record id="cron_duca_alertas" model="ir.cron">
            <field name="name">Alertas Vencimiento Lotes DUCA (ZOLI)</field>
            <field name="model_id" ref="stock.model_stock_lot"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_duca_alertas()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="nextcall" eval="
                (DateTime.now() + timedelta(days=1)).replace(
                    hour=7, minute=0, second=0
                ).strftime('%Y-%m-%d %H:%M:%S')
            "/>
        </record>

        <!-- Migración: referencia interna para contactos existentes -->
        <function model="res.partner" name="_init_refs_fiscal_hn"/>
        <!-- Migración: normalizar code/name de secuencias fiscales (XML multilínea) -->
        <function model="ir.sequence" name="_init_normalize_fiscal_codes"/>
    </data>

    <!-- Catálogo de impuestos fiscales HN. Fuera de noupdate para que se
         (re)cree en cada actualización si faltan; el método es idempotente. -->
    <data>
        <function model="account.tax" name="_init_fiscal_hn_taxes"/>
    </data>
</odoo>
