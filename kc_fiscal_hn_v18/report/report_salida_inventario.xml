<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="id_report_salida_inventario">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <t t-set="address" t-value="None"/>
                        <t t-set="salida_lines" t-value="o._get_salida_inventario_lines()"/>
                        <t t-set="pending_lines" t-value="o._get_salida_pending_backorder_lines()"/>
                        <t t-set="line_counter" t-value="0"/>
                        <t t-set="motorista_nombre"
                           t-value="(o.transporter_name or o.conductor or '').strip()"/>
                        <t t-set="vehiculo_info"
                           t-value="(o.vehicle_info or o.vehiculo or '').strip()"/>

                        <div class="page">
                            <t t-call="kc_fiscal_hn_v18.header_salida_inventario_layout"/>
                            <t t-call="kc_fiscal_hn_v18.salida_inventario_info_block"/>

                            <table style="width:100%; border-collapse:collapse; font-size:11px; color:#111827; margin-bottom:12px;"
                                   name="inventory_out_line_table">
                                <thead>
                                    <tr style="background-color:#1a4fa0; -webkit-print-color-adjust:exact;">
                                        <th style="width:6%; text-align:center; font-size:10px; font-weight:700; letter-spacing:0.8px; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                            #
                                        </th>
                                        <th style="width:34%; text-align:left; font-size:10px; font-weight:700; letter-spacing:0.8px; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                            Producto
                                        </th>
                                        <th style="width:22%; text-align:left; font-size:10px; font-weight:700; letter-spacing:0.8px; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                            Dimensión
                                        </th>
                                        <th style="width:18%; text-align:left; font-size:10px; font-weight:700; letter-spacing:0.8px; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                            Lote / Serie
                                        </th>
                                        <th style="width:12%; text-align:right; font-size:10px; font-weight:700; letter-spacing:0.8px; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                            Cantidad
                                        </th>
                                        <th style="width:8%; text-align:center; font-size:10px; font-weight:700; letter-spacing:0.8px; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                            UdM
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="report_move_lines" t-value="o.move_line_ids_without_package or o.move_line_ids"/>
                                    <t t-foreach="report_move_lines" t-as="ml">
                                        <t t-if="ml.product_id">
                                            <t t-set="line_counter" t-value="line_counter + 1"/>
                                            <tr t-att-style="'border-bottom:1px solid #eef0f3;' + (' background-color:#f8fafc; -webkit-print-color-adjust:exact;' if line_counter % 2 == 1 else '')">
                                                <td style="padding:7px 6px; text-align:center; color:#6b7280;">
                                                    <span t-esc="line_counter"/>
                                                </td>
                                                <td style="padding:7px 6px; vertical-align:top;">
                                                    <span style="font-weight:600; color:#111827;"
                                                          t-esc="o._salida_strip_product_code(ml.product_id.display_name)"/>
                                                </td>
                                                <td style="padding:7px 6px; font-size:10px; color:#4b5563; vertical-align:top;">
                                                    <t t-if="ml.lot_id and ml.lot_id.technical_description">
                                                        <span t-esc="ml.lot_id.technical_description"/>
                                                    </t>
                                                    <t t-elif="ml.move_id.sale_line_id and ml.move_id.sale_line_id.technical_description">
                                                        <span t-esc="ml.move_id.sale_line_id.technical_description"/>
                                                    </t>
                                                    <t t-else="">—</t>
                                                </td>
                                                <td style="padding:7px 6px; color:#111827; vertical-align:top;">
                                                    <span t-esc="ml.lot_id.name or ml.lot_name or '—'"/>
                                                </td>
                                                <td style="padding:7px 6px; text-align:right; font-weight:700; color:#0c2d5e; vertical-align:top;">
                                                    <t t-if="o.state == 'done'">
                                                        <span t-esc="'%.2f' % ml.quantity"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="'%.2f' % (ml.quantity or ml.product_uom_qty or ml.move_id.product_uom_qty)"/>
                                                    </t>
                                                </td>
                                                <td style="padding:7px 6px; text-align:center; color:#6b7280; vertical-align:top;">
                                                    <span t-esc="ml.product_uom_id.name or ''"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                    <t t-if="not report_move_lines">
                                        <t t-foreach="salida_lines" t-as="line">
                                            <t t-set="line_counter" t-value="line_counter + 1"/>
                                            <tr t-att-style="'border-bottom:1px solid #eef0f3;' + (' background-color:#f8fafc; -webkit-print-color-adjust:exact;' if line_counter % 2 == 1 else '')">
                                                <td style="padding:7px 6px; text-align:center; color:#6b7280;">
                                                    <span t-esc="line_counter"/>
                                                </td>
                                                <td style="padding:7px 6px; vertical-align:top;">
                                                    <span style="font-weight:600; color:#111827;" t-esc="line['name']"/>
                                                </td>
                                                <td style="padding:7px 6px; font-size:10px; color:#4b5563; vertical-align:top;">
                                                    <span t-esc="line['technical_description'] or '—'"/>
                                                </td>
                                                <td style="padding:7px 6px; color:#111827; vertical-align:top;">
                                                    <span t-esc="line['lot'] or '—'"/>
                                                </td>
                                                <td style="padding:7px 6px; text-align:right; font-weight:700; color:#0c2d5e; vertical-align:top;">
                                                    <span t-esc="'%.2f' % line['qty']"/>
                                                </td>
                                                <td style="padding:7px 6px; text-align:center; color:#6b7280; vertical-align:top;">
                                                    <span t-esc="line['uom']"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                    <t t-if="not report_move_lines and not salida_lines">
                                        <tr>
                                            <td colspan="6"
                                                style="padding:12px 6px; text-align:center; color:#6b7280; border-bottom:1px solid #eef0f3;">
                                                Sin productos registrados en esta entrega.
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <t t-if="pending_lines">
                                <div style="margin-top:14px; page-break-inside:avoid;">
                                    <div style="font-size:10px; letter-spacing:1px; color:#1a4fa0; text-transform:uppercase; font-weight:700; margin-bottom:8px; border-bottom:2px solid #1a4fa0; padding-bottom:4px;">
                                        Cantidades restantes sin entregar
                                    </div>
                                    <table style="width:100%; border-collapse:collapse; font-size:11px; color:#111827;"
                                           name="remaining_qty_table">
                                        <thead>
                                            <tr style="background-color:#1a4fa0; -webkit-print-color-adjust:exact;">
                                                <th style="width:75%; text-align:left; font-size:10px; font-weight:700; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                                    Producto
                                                </th>
                                                <th style="width:25%; text-align:right; font-size:10px; font-weight:700; color:#ffffff; text-transform:uppercase; padding:8px 6px;">
                                                    Cantidad
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="pending_lines" t-as="bo_line">
                                                <tr style="border-bottom:1px solid #eef0f3;">
                                                    <td style="padding:7px 6px;">
                                                        <div style="font-weight:600; color:#111827;">
                                                            <span t-esc="bo_line['name']"/>
                                                        </div>
                                                        <t t-if="bo_line.get('technical_description')">
                                                            <div style="font-size:9px; color:#4b5563; margin-top:2px;">
                                                                <span t-esc="bo_line['technical_description']"/>
                                                            </div>
                                                        </t>
                                                    </td>
                                                    <td style="padding:7px 6px; text-align:right; font-weight:700; color:#0c2d5e;">
                                                        <span t-esc="'%.2f' % bo_line['qty']"/>
                                                        <span style="font-weight:400; color:#6b7280;" t-esc="' %s' % bo_line['uom']"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>

                            <t t-if="o.note">
                                <div style="margin-top:14px; font-size:10px; color:#111827; page-break-inside:avoid; padding:10px 12px; background-color:#f8fafc; border:1px solid #e5e7eb; border-radius:6px; -webkit-print-color-adjust:exact;">
                                    <div style="font-size:9px; letter-spacing:1px; color:#1a4fa0; text-transform:uppercase; font-weight:700; margin-bottom:6px;">
                                        Observaciones
                                    </div>
                                    <div style="color:#374151; line-height:1.45;">
                                        <span t-field="o.note"/>
                                    </div>
                                </div>
                            </t>

                            <!-- Datos motorista / vehículo -->
                            <div style="margin-top:14px; page-break-inside:avoid; background-color:#f0f5ff; border:1px solid #c7d7f5; border-radius:6px; padding:12px 14px; -webkit-print-color-adjust:exact;">
                                <div style="font-size:9px; letter-spacing:1.2px; color:#1a4fa0; text-transform:uppercase; font-weight:700; margin-bottom:8px;">
                                    Datos del transportista
                                </div>
                                <table style="width:100%; border-collapse:collapse; font-size:10px; color:#111827;">
                                    <tr>
                                        <td style="width:50%; padding:4px 10px 4px 0; vertical-align:top;">
                                            <div style="color:#6b7280; font-size:8px; letter-spacing:0.8px; text-transform:uppercase; margin-bottom:2px;">Nombre del transportista</div>
                                            <div style="font-weight:600; color:#0c2d5e;">
                                                <t t-if="motorista_nombre" t-esc="motorista_nombre"/>
                                                <t t-else="">—</t>
                                            </div>
                                        </td>
                                        <td style="width:50%; padding:4px 0 4px 10px; vertical-align:top;">
                                            <div style="color:#6b7280; font-size:8px; letter-spacing:0.8px; text-transform:uppercase; margin-bottom:2px;">RTN / Identidad</div>
                                            <div style="font-weight:600; color:#111827; font-family:'Courier New',monospace;">
                                                <t t-if="o.transporter_rtn" t-esc="o.transporter_rtn"/>
                                                <t t-else="">—</t>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:8px 10px 4px 0; vertical-align:top;">
                                            <div style="color:#6b7280; font-size:8px; letter-spacing:0.8px; text-transform:uppercase; margin-bottom:2px;">Marca y No. de Placa</div>
                                            <div style="font-weight:600; color:#111827;">
                                                <t t-if="vehiculo_info" t-esc="vehiculo_info"/>
                                                <t t-else="">—</t>
                                            </div>
                                        </td>
                                        <td style="padding:8px 0 4px 10px; vertical-align:top;">
                                            <div style="color:#6b7280; font-size:8px; letter-spacing:0.8px; text-transform:uppercase; margin-bottom:2px;">Licencia de conducir</div>
                                            <div style="font-weight:600; color:#111827;">
                                                <t t-if="o.driver_license" t-esc="o.driver_license"/>
                                                <t t-else="">—</t>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <table style="width:100%; border-collapse:collapse; margin-top:36px; font-size:10px; color:#111827; page-break-inside:avoid;">
                                <tr>
                                    <td style="width:25%; text-align:center; padding:4px 10px; vertical-align:bottom;">
                                        <div style="height:36px;"/>
                                        <div style="border-top:1px solid #111827; padding-top:6px; margin:0 6px; color:#374151;">
                                            Entregado por
                                        </div>
                                    </td>
                                    <td style="width:25%; text-align:center; padding:4px 10px; vertical-align:bottom;">
                                        <div style="height:36px;"/>
                                        <div style="border-top:1px solid #111827; padding-top:6px; margin:0 6px; color:#374151;">
                                            Revisado por
                                        </div>
                                    </td>
                                    <td style="width:25%; text-align:center; padding:4px 10px; vertical-align:bottom;">
                                        <div style="height:22px; font-weight:700; color:#0c2d5e; font-size:10px; line-height:1.2;">
                                            <t t-if="motorista_nombre" t-esc="motorista_nombre"/>
                                        </div>
                                        <div style="height:14px;"/>
                                        <div style="border-top:1px solid #111827; padding-top:6px; margin:0 6px; color:#374151;">
                                            Motorista
                                        </div>
                                    </td>
                                    <td style="width:25%; text-align:center; padding:4px 10px; vertical-align:bottom;">
                                        <div style="height:36px;"/>
                                        <div style="border-top:1px solid #111827; padding-top:6px; margin:0 6px; color:#374151;">
                                            Nombre y sello recibido
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <t t-call="kc_fiscal_hn_v18.salida_inventario_footer"/>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
