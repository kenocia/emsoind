<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="id_report_guia_remision">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <t t-set="address" t-value="None"/>
                        <t t-set="guia_lines" t-value="o._get_guia_remision_lines()"/>
                        <t t-set="has_lot" t-value="any(line.get('lot') for line in guia_lines)"/>
                        <t t-set="line_counter" t-value="0"/>

                        <div class="page">
                            <t t-call="kc_fiscal_hn_v18.header_custom_layout_picking"/>
                            <t t-call="kc_fiscal_hn_v18.guia_remision_info_block"/>

                            <table style="width:100%; border-collapse:collapse; font-size:11px; color:#111827; margin-bottom:12px;"
                                   name="guia_product_table">
                                <thead>
                                    <tr>
                                        <th style="width:6%; text-align:center; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                            #
                                        </th>
                                        <th style="width:44%; text-align:left; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                            Producto / Descripción
                                        </th>
                                        <th style="width:14%; text-align:right; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                            Cantidad
                                        </th>
                                        <th style="width:12%; text-align:center; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                            UdM
                                        </th>
                                        <t t-if="has_lot">
                                            <th style="width:24%; text-align:left; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                                Lote / Serie
                                            </th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="guia_lines" t-as="line">
                                        <t t-set="line_counter" t-value="line_counter + 1"/>
                                        <tr t-att-style="'background-color:#fafbfc; -webkit-print-color-adjust:exact;' if line_counter % 2 == 1 else ''">
                                            <td style="padding:5px 4px; border-bottom:1px solid #eef0f3; text-align:center; color:#111827;">
                                                <span t-esc="line_counter"/>
                                            </td>
                                            <td style="padding:5px 4px; border-bottom:1px solid #eef0f3;">
                                                <span style="font-weight:600; color:#111827;" t-esc="line['name']"/>
                                                <t t-if="line.get('description')">
                                                    <br/>
                                                    <span style="font-size:10px; color:#111827;" t-esc="line['description']"/>
                                                </t>
                                            </td>
                                            <td style="padding:5px 4px; border-bottom:1px solid #eef0f3; text-align:right; font-weight:600; color:#111827;">
                                                <span t-esc="'%.2f' % line['qty']"/>
                                            </td>
                                            <td style="padding:5px 4px; border-bottom:1px solid #eef0f3; text-align:center;">
                                                <span t-esc="line['uom']"/>
                                            </td>
                                            <t t-if="has_lot">
                                                <td style="padding:5px 4px; border-bottom:1px solid #eef0f3;">
                                                    <span t-esc="line.get('lot') or '—'"/>
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                    <t t-if="not guia_lines">
                                        <tr>
                                            <td t-att-colspan="5 if has_lot else 4"
                                                style="padding:12px 4px; text-align:center; color:#111827; border-bottom:1px solid #eef0f3;">
                                                Sin productos registrados en esta entrega.
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <t t-call="kc_fiscal_hn_v18.guia_remision_transport_block"/>

                            <table style="width:100%; border-collapse:collapse; margin-top:20px; font-size:10px; color:#111827; page-break-inside:avoid;">
                                <tr>
                                    <td style="width:55%; vertical-align:top; padding-right:12px;">
                                        <div style="font-size:9px; color:#111827; line-height:1.5;">
                                            <div>Original: Destinatario</div>
                                            <div>Copia 1: Obligado Tributario Emisor</div>
                                            <div>Copia 2: Servicio de Administración de Rentas</div>
                                        </div>
                                        <t t-if="o.numeroInicial or o.numeroFinal or o.fechaLimiteEmision">
                                            <div style="margin-top:10px; padding:8px 10px; background-color:#f7f8fa; border:1px solid #e5e7eb; border-radius:6px; -webkit-print-color-adjust:exact;">
                                                <t t-if="o.fechaLimiteEmision">
                                                    <div>
                                                        <span style="color:#111827;">Fecha límite emisión: </span>
                                                        <strong style="color:#111827;"
                                                                t-esc="o.fechaLimiteEmision.strftime('%d/%m/%Y') if o.fechaLimiteEmision else ''"/>
                                                    </div>
                                                </t>
                                                <t t-if="o.numeroInicial or o.numeroFinal">
                                                    <div>
                                                        <span style="color:#111827;">Rango autorizado: </span>
                                                        <strong style="color:#111827;" t-field="o.numeroInicial"/>
                                                        —
                                                        <strong style="color:#111827;" t-field="o.numeroFinal"/>
                                                    </div>
                                                </t>
                                            </div>
                                        </t>
                                    </td>
                                    <td style="width:45%; vertical-align:bottom; text-align:center; padding-top:30px;">
                                        <div style="border-top:1px solid #111827; padding-top:6px; margin:0 20px;">
                                            <span style="color:#111827;">Firma y sello del transportista</span>
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <t t-set="sar_page_num" t-value="1"/>
                            <t t-set="sar_total_pages" t-value="1"/>
                            <t t-call="kc_fiscal_hn_v18.invoice_sar_fiscal_footer"/>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
