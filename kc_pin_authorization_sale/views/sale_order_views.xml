<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_kc_pin" model="ir.ui.view">
        <field name="name">sale.order.form.kc.pin</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Autorización por PIN"
                      name="kc_pin_authorization"
                      invisible="not kc_pin_authorized_employee_id">
                    <group>
                        <field name="kc_pin_authorized_employee_id" readonly="1"/>
                        <field name="kc_pin_authorization_date" readonly="1"/>
                        <field name="kc_pin_authorized_user_id" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
