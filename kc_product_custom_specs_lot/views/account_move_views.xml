<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_invoice_technical" model="ir.ui.view">
        <field name="name">account.move.form.invoice.technical</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='name']" position="after">
                <field name="kc_show_technical_on_invoice" column_invisible="1"/>
                <field name="lot_id" string="Lote" optional="show"
                       readonly="1"
                       column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
                <field name="technical_description" string="Especificaciones" optional="show"
                       readonly="1"
                       column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
                <field name="kc_unit_cost" optional="hide" readonly="1"
                       column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
                <field name="kc_margin" optional="hide" readonly="1"
                       column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
                <field name="kc_margin_percent" optional="hide" readonly="1" widget="percentage"
                       column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
