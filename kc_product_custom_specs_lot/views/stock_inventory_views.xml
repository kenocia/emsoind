<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista para menú Ubicaciones (always_show_loc) -->
    <record id="view_stock_quant_tree_technical_locations" model="ir.ui.view">
        <field name="name">stock.quant.tree.technical.locations</field>
        <field name="model">stock.quant</field>
        <field name="priority">25</field>
        <field name="arch" type="xml">
            <list string="Ubicaciones" create="false" edit="false" delete="false"
                  default_order="location_id, product_id, lot_id">
                <field name="location_id" string="Ubicación"/>
                <field name="product_id" string="Producto"/>
                <field name="lot_id" string="Número de serie/lote"
                       groups="stock.group_production_lot"/>
                <field name="lot_technical_description" string="Especificaciones"/>
                <field name="quantity" string="Cantidad a la mano" sum="Total"/>
                <field name="reserved_quantity" string="Cantidad reservada" sum="Total"/>
                <field name="available_quantity" string="Disponible" optional="show" sum="Total"/>
                <field name="lot_technical_key" string="Clave técnica" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Herencia vista estándar de quants (si se usa view_stock_quant_tree) -->
    <record id="view_stock_quant_tree_technical" model="ir.ui.view">
        <field name="name">stock.quant.tree.technical</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="lot_technical_description" string="Especificaciones" readonly="1"/>
                <field name="lot_technical_key" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Herencia lista inventario (modo inventory_report_list) -->
    <record id="view_stock_quant_inventory_list_technical" model="ir.ui.view">
        <field name="name">stock.quant.inventory.list.technical</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//list//field[@name='lot_id']" position="after">
                <field name="lot_technical_description" string="Especificaciones" readonly="1"/>
                <field name="lot_technical_key" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_move_tree_technical" model="ir.ui.view">
        <field name="name">stock.move.tree.technical</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_tree"/>
        <field name="arch" type="xml">
            <field name="product_id" position="after">
                <field name="kc_lot_id" optional="hide"/>
                <field name="lot_technical_description" optional="show" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="view_stock_move_line_tree_technical" model="ir.ui.view">
        <field name="name">stock.move.line.tree.technical</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <field name="lot_id" position="after">
                <field name="lot_technical_description" string="Especificaciones" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="view_stock_move_line_operation_tree_technical" model="ir.ui.view">
        <field name="name">stock.move.line.operation.tree.technical</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree"/>
        <field name="arch" type="xml">
            <field name="lot_id" position="before">
                <field name="kc_allowed_lot_ids" column_invisible="1"/>
            </field>
            <field name="lot_id" position="attributes">
                <attribute name="domain">[('id', 'in', kc_allowed_lot_ids)]</attribute>
            </field>
            <field name="lot_id" position="after">
                <field name="lot_technical_description" optional="show" readonly="1"/>
                <field name="sale_technical_key" optional="hide" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="view_picking_form_technical" model="ir.ui.view">
        <field name="name">stock.picking.form.technical</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']//list//field[@name='product_id']" position="after">
                <field name="kc_lot_id" optional="hide"/>
                <field name="lot_technical_description" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
