<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kc_technical_orderpoint_list" model="ir.ui.view">
        <field name="name">kc.technical.orderpoint.list</field>
        <field name="model">kc.technical.orderpoint</field>
        <field name="arch" type="xml">
            <list string="Reglas de Abastecimiento Técnico" editable="bottom"
                  decoration-warning="qty_to_order_spec &gt; 0">
                <field name="product_id"/>
                <field name="product_tmpl_id" column_invisible="1"/>
                <field name="technical_configuration_id"/>
                <field name="technical_key" optional="hide"/>
                <field name="location_id"/>
                <field name="product_min_qty"/>
                <field name="product_max_qty"/>
                <field name="qty_on_hand_spec" readonly="1"/>
                <field name="qty_to_order_spec" readonly="1"/>
                <field name="product_uom"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_kc_technical_orderpoint_form" model="ir.ui.view">
        <field name="name">kc.technical.orderpoint.form</field>
        <field name="model">kc.technical.orderpoint</field>
        <field name="arch" type="xml">
            <form string="Regla de Abastecimiento Técnico">
                <sheet>
                    <widget name="web_ribbon" title="Archivado"
                            bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="product_tmpl_id" invisible="1"/>
                            <field name="technical_configuration_id"/>
                            <field name="technical_description" readonly="1"
                                   invisible="not technical_configuration_id"/>
                            <field name="technical_key" invisible="1"/>
                        </group>
                        <group>
                            <field name="location_id"/>
                            <field name="product_min_qty"/>
                            <field name="product_max_qty"/>
                            <field name="product_uom"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group string="Estado de inventario (por especificación)">
                        <group>
                            <field name="qty_on_hand_spec" readonly="1"/>
                            <field name="qty_to_order_spec" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kc_technical_orderpoint_search" model="ir.ui.view">
        <field name="name">kc.technical.orderpoint.search</field>
        <field name="model">kc.technical.orderpoint</field>
        <field name="arch" type="xml">
            <search string="Buscar Reglas de Abastecimiento Técnico">
                <field name="product_id"/>
                <field name="technical_configuration_id"/>
                <field name="technical_key"/>
                <field name="location_id"/>
                <separator/>
                <group expand="0" string="Agrupar Por">
                    <filter name="group_product" string="Producto"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_location" string="Ubicación"
                            context="{'group_by': 'location_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kc_technical_orderpoint" model="ir.actions.act_window">
        <field name="name">Abastecimiento Técnico</field>
        <field name="res_model">kc.technical.orderpoint</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_kc_technical_orderpoint_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define una regla de abastecimiento por especificación técnica
            </p>
            <p>
                Establece un mínimo de inventario por cada configuración técnica
                (clave técnica) de un producto. El stock se evalúa sumando los
                lotes que comparten esa especificación.
            </p>
        </field>
    </record>

    <menuitem id="menu_kc_technical_orderpoint"
              name="Abastecimiento Técnico"
              parent="stock.menu_stock_root"
              action="action_kc_technical_orderpoint"
              sequence="95"
              groups="stock.group_stock_user"/>

</odoo>
