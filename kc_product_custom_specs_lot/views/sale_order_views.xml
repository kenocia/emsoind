<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_technical" model="ir.ui.view">
        <field name="name">sale.order.form.technical</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="after">
                <button name="action_open_specs_wizard"
                        type="object"
                        icon="fa-cog"
                        title="Configurar especificaciones"
                        invisible="not show_technical_section"
                        class="btn-link"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']" position="after">
                <field name="show_technical_section" column_invisible="1"/>
                <field name="kc_lot_policy" column_invisible="1"
                       groups="sales_team.group_sale_manager,stock.group_stock_manager"/>
                <field name="technical_description" optional="show" readonly="1"/>
                <field name="compatible_lot_qty" optional="hide" readonly="1" string="Stock compat."
                       groups="sales_team.group_sale_manager,stock.group_stock_manager"/>
                <field name="lot_id" optional="hide" readonly="1" string="Lote"
                       groups="sales_team.group_sale_manager,stock.group_stock_manager"/>
                <field name="kc_unit_cost" optional="hide" readonly="1"/>
                <field name="kc_margin" optional="hide" readonly="1"/>
                <field name="kc_margin_percent" optional="hide" readonly="1" widget="percentage"/>
                <field name="has_compatible_stock" column_invisible="1"/>
                <button name="action_copy_technical_specs"
                        type="object"
                        icon="fa-copy"
                        title="Copiar especificaciones"
                        invisible="not show_technical_section"/>
            </xpath>
        </field>
    </record>
</odoo>
