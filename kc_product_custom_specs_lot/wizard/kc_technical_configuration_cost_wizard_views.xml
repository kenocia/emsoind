<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kc_technical_configuration_cost_wizard_view_form" model="ir.ui.view">
        <field name="name">kc.technical.configuration.cost.wizard.form</field>
        <field name="model">kc.technical.configuration.cost.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar costos de matriz técnica">
                <group invisible="result_message">
                    <field name="file_name" invisible="1"/>
                    <field name="file_data" filename="file_name"/>
                </group>
                <group invisible="not result_message">
                    <field name="result_message" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_import"
                            string="Importar"
                            type="object"
                            class="btn-primary"
                            invisible="result_message"/>
                    <button string="Cerrar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kc_technical_configuration_cost_import" model="ir.actions.act_window">
        <field name="name">Importar costos</field>
        <field name="res_model">kc.technical.configuration.cost.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
