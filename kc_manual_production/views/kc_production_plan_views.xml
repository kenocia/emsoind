<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="kc_production_plan_line_view_gantt" model="ir.ui.view">
        <field name="name">kc.production.plan.line.gantt</field>
        <field name="model">kc.production.plan.line</field>
        <field name="arch" type="xml">
            <gantt date_start="date_planned_start"
                   date_stop="date_planned_end"
                   default_group_by="work_center_id"
                   color="color"
                   string="Planificación de Producción"
                   create="0"
                   decoration-danger="is_delayed"
                   decoration-warning="is_overloaded">
                <field name="work_center_id"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="technical_description"/>
                <field name="technical_key"/>
                <field name="planned_qty"/>
                <field name="origin_type"/>
                <field name="state"/>
                <field name="is_delayed"/>
                <field name="is_overloaded"/>
            </gantt>
        </field>
    </record>

    <record id="kc_production_plan_line_view_list" model="ir.ui.view">
        <field name="name">kc.production.plan.line.list</field>
        <field name="model">kc.production.plan.line</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="name"/>
                <field name="origin_type"/>
                <field name="work_center_id"/>
                <field name="production_line_id" optional="show"/>
                <field name="sale_order_id" optional="show"/>
                <field name="commitment_date" optional="show"/>
                <field name="product_id"/>
                <field name="technical_description"/>
                <field name="technical_key" optional="show"/>
                <field name="planned_qty"/>
                <field name="qty_produced" optional="show"/>
                <field name="qty_remaining"/>
                <field name="date_planned_start"/>
                <field name="date_planned_end"/>
                <field name="state" widget="badge"
                        decoration-info="state == 'confirmed'"
                        decoration-warning="state == 'in_progress'"
                        decoration-success="state == 'done'"
                        decoration-danger="is_delayed"
                        decoration-muted="state == 'cancelled'"/>
                <field name="is_delayed" optional="hide"/>
                <field name="is_overloaded" optional="hide"/>
                <field name="priority" widget="priority" optional="show"/>
            </list>
        </field>
    </record>

    <record id="kc_production_plan_line_view_form" model="ir.ui.view">
        <field name="name">kc.production.plan.line.form</field>
        <field name="model">kc.production.plan.line</field>
        <field name="arch" type="xml">
            <form string="Bloque de Planificación">
                <header>
                    <button name="action_confirm" type="object" string="Confirmar"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_create_entry" type="object"
                            string="Generar RP" class="oe_highlight"
                            invisible="state not in ('draft', 'confirmed', 'in_progress') or qty_remaining &lt;= 0"/>
                    <button name="action_cancel" type="object" string="Cancelar"
                            invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_draft" type="object" string="Volver a Borrador"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Origen">
                            <field name="origin_type"
                                   readonly="state not in ('draft', 'confirmed')"/>
                            <field name="sale_order_id"
                                   invisible="origin_type != 'sale_order'"
                                   required="origin_type == 'sale_order'"
                                   readonly="state not in ('draft', 'confirmed')"
                                   options="{'no_create': True}"/>
                            <field name="sale_order_line_id"
                                   invisible="origin_type != 'sale_order'"
                                   required="origin_type == 'sale_order'"
                                   readonly="state not in ('draft', 'confirmed')"
                                   options="{'no_create': True}"
                                   domain="[('order_id', '=', sale_order_id), ('display_type', '=', False)]"/>
                            <field name="product_id"
                                   readonly="origin_type == 'sale_order' or state not in ('draft', 'confirmed')"
                                   required="1"
                                   options="{'no_create': True}"/>
                            <field name="product_tmpl_id" invisible="1"/>
                            <field name="technical_configuration_id"
                                   invisible="origin_type != 'replenishment'"
                                   required="origin_type == 'replenishment'"
                                   readonly="state not in ('draft', 'confirmed')"
                                   options="{'no_create': True}"
                                   context="{'default_product_tmpl_id': product_tmpl_id}"/>
                            <field name="technical_description"
                                   string="Descripción técnica"
                                   readonly="1"
                                   force_save="1"
                                   placeholder="Especificaciones de producción"/>
                            <field name="technical_key"
                                   string="Clave técnica"
                                   readonly="1"
                                   force_save="1"/>
                            <field name="sol_technical_description" invisible="1"/>
                            <field name="planned_qty"
                                   readonly="state not in ('draft', 'confirmed')"/>
                        </group>
                        <group string="Agenda">
                            <field name="allowed_work_center_ids" invisible="1"/>
                            <field name="work_center_id"
                                   readonly="state not in ('draft', 'confirmed')"
                                   options="{'no_create': True}"/>
                            <field name="production_line_id"/>
                            <field name="date_planned_start"
                                   readonly="state not in ('draft', 'confirmed')"/>
                            <field name="date_planned_end"
                                   readonly="state not in ('draft', 'confirmed')"/>
                            <field name="priority"
                                   readonly="state not in ('draft', 'confirmed')"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Registro de Producción vinculado">
                        <group>
                            <field name="entry_id"/>
                            <field name="qty_produced"/>
                            <field name="qty_remaining"/>
                            <field name="variance"/>
                        </group>
                        <group>
                            <field name="is_delayed"/>
                            <field name="is_overloaded"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Notas del bloque..."
                               readonly="state in ('done', 'cancelled')"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Para imprimir el documento de trabajo use
                        <strong>Generar RP</strong> y luego Imprimir en el Registro de Producción.
                    </div>
                </sheet>
                <!-- Diálogo Gantt: en Hecho solo Cerrar (sin Guardar / Eliminar). -->
                <footer invisible="state != 'done'">
                    <button string="Cerrar" special="cancel" class="btn btn-primary" close="1"/>
                </footer>
                <footer invisible="state == 'done'" replace="0"/>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="kc_production_plan_line_view_kanban" model="ir.ui.view">
        <field name="name">kc.production.plan.line.kanban</field>
        <field name="model">kc.production.plan.line</field>
        <field name="arch" type="xml">
            <kanban create="false" default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="product_id"/>
                <field name="technical_description"/>
                <field name="technical_key"/>
                <field name="work_center_id"/>
                <field name="planned_qty"/>
                <field name="qty_produced"/>
                <field name="qty_remaining"/>
                <field name="origin_type"/>
                <field name="state"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <strong><field name="name"/></strong>
                            <div><field name="origin_type"/></div>
                            <div><field name="product_id"/></div>
                            <div class="text-muted" t-if="record.technical_description.raw_value">
                                <field name="technical_description"/>
                            </div>
                            <div class="text-muted" t-if="record.technical_key.raw_value">
                                <field name="technical_key"/>
                            </div>
                            <div><field name="work_center_id"/></div>
                            <div>Plan: <field name="planned_qty"/> · Pend: <field name="qty_remaining"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="kc_production_plan_line_view_search" model="ir.ui.view">
        <field name="name">kc.production.plan.line.search</field>
        <field name="model">kc.production.plan.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="work_center_id"/>
                <field name="product_id"/>
                <field name="technical_description"/>
                <field name="technical_key"/>
                <field name="sale_order_id"/>
                <field name="commitment_date"/>
                <filter name="filter_sale" string="Orden de Venta"
                        domain="[('origin_type', '=', 'sale_order')]"/>
                <filter name="filter_replenishment" string="Abastecimiento"
                        domain="[('origin_type', '=', 'replenishment')]"/>
                <filter name="filter_delayed" string="Retrasados"
                        domain="[('is_delayed', '=', True)]"/>
                <filter name="filter_pending_produce" string="Pendiente de producir"
                        domain="[('state', 'in', ('confirmed', 'in_progress')), ('qty_remaining', '&gt;', 0)]"/>
                <group>
                    <filter name="group_sale_order" string="Orden de Venta"
                            context="{'group_by': 'sale_order_id'}"/>
                    <filter name="group_commitment_date" string="Fecha de entrega"
                            context="{'group_by': 'commitment_date:day'}"/>
                    <filter name="group_center" string="Centro"
                            context="{'group_by': 'work_center_id'}"/>
                    <filter name="group_origin" string="Origen"
                            context="{'group_by': 'origin_type'}"/>
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="kc_production_plan_line_action" model="ir.actions.act_window">
        <field name="name">Planificación</field>
        <field name="res_model">kc.production.plan.line</field>
        <field name="view_mode">gantt,list,form</field>
        <field name="search_view_id" ref="kc_production_plan_line_view_search"/>
        <field name="context">{'group_by': 'sale_order_id'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Planifique desde <em>Órdenes Pendientes de Planificar</em> o
                <em>Planificar Abastecimiento</em>. El Gantt solo agenda bloques existentes.
                Para imprimir: vista lista → seleccionar → Acciones →
                <em>Imprimir planificación</em>.
            </p>
        </field>
    </record>

    <!-- Cola B: planificado con saldo pendiente de fabricar. -->
    <record id="kc_production_plan_pending_produce_action" model="ir.actions.act_window">
        <field name="name">Pendientes de Producir</field>
        <field name="res_model">kc.production.plan.line</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">
            [('state', 'in', ('confirmed', 'in_progress')), ('qty_remaining', '&gt;', 0)]
        </field>
        <field name="context">{
            'create': False,
            'search_default_group_sale_order': 1,
        }</field>
        <field name="search_view_id" ref="kc_production_plan_line_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay planes con cantidad pendiente de producir.
            </p>
            <p>
                Aquí se ven bloques ya planificados con saldo por fabricar.
                Abra el bloque y use <strong>Generar RP</strong> para registrar
                la producción (incluye parciales).
            </p>
        </field>
    </record>

    <record id="kc_production_plan_print_selection_action" model="ir.actions.server">
        <field name="name">Imprimir planificación</field>
        <field name="model_id" ref="model_kc_production_plan_line"/>
        <field name="binding_model_id" ref="model_kc_production_plan_line"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('kc_manual_production.action_report_kc_plan_selection').report_action(records)</field>
    </record>

    <record id="kc_production_plan_line_replenishment_action" model="ir.actions.act_window">
        <field name="name">Planificar Abastecimiento</field>
        <field name="res_model">kc.production.plan.line</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{
            'default_origin_type': 'replenishment',
            'form_view_initial_mode': 'edit',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cree un bloque de plan sin OV para stock de reposición.
                Luego use Generar RP para el documento imprimible.
            </p>
        </field>
    </record>

</odoo>
