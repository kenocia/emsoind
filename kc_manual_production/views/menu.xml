<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="kc_production_report_action" model="ir.actions.act_window">
        <field name="name">Producciones por Período</field>
        <field name="res_model">kc.production.entry</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="kc_production_entry_view_search"/>
        <field name="context">{'search_default_group_state': 1, 'search_default_filter_this_month': 1}</field>
    </record>

    <record id="kc_consumption_report_action" model="ir.actions.act_window">
        <field name="name">Consumos por Período</field>
        <field name="res_model">kc.production.consumption</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="kc_production_consumption_view_search"/>
        <field name="context">{'search_default_group_state': 1, 'search_default_filter_this_month': 1}</field>
    </record>

