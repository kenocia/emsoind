<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="kc_production_plan_line_planner_rule" model="ir.rule">
        <field name="name">KC Plan: planificador solo ve planes de sus líneas</field>
        <field name="model_id" ref="model_kc_production_plan_line"/>
        <field name="domain_force">[('production_line_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('kc_production_group_planner'))]"/>
    </record>

    <record id="kc_production_plan_line_user_rule" model="ir.rule">
        <field name="name">KC Plan: operador solo ve planes de sus líneas</field>
        <field name="model_id" ref="model_kc_production_plan_line"/>
        <field name="domain_force">[('production_line_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('kc_production_group_user'))]"/>
    </record>

    <record id="kc_production_plan_line_manager_rule" model="ir.rule">
        <field name="name">KC Plan: administrador ve todos</field>
        <field name="model_id" ref="model_kc_production_plan_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('kc_production_group_manager'))]"/>
    </record>

    <record id="kc_production_plan_line_stock_manager_rule" model="ir.rule">
        <field name="name">KC Plan: stock manager ve todos</field>
        <field name="model_id" ref="model_kc_production_plan_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>

    <record id="kc_production_backlog_planner_rule" model="ir.rule">
        <field name="name">KC Backlog: planificador solo ve sus líneas</field>
        <field name="model_id" ref="model_kc_production_backlog"/>
        <field name="domain_force">[('production_line_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('kc_production_group_planner'))]"/>
    </record>

    <record id="kc_production_backlog_user_rule" model="ir.rule">
        <field name="name">KC Backlog: operador solo ve sus líneas</field>
        <field name="model_id" ref="model_kc_production_backlog"/>
        <field name="domain_force">[('production_line_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('kc_production_group_user'))]"/>
    </record>

    <record id="kc_production_backlog_manager_rule" model="ir.rule">
        <field name="name">KC Backlog: administrador ve todos</field>
        <field name="model_id" ref="model_kc_production_backlog"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('kc_production_group_manager'))]"/>
    </record>

    <record id="kc_production_backlog_stock_manager_rule" model="ir.rule">
        <field name="name">KC Backlog: stock manager ve todos</field>
        <field name="model_id" ref="model_kc_production_backlog"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>

</odoo>
