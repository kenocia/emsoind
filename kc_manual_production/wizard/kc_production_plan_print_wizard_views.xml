<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="kc_production_plan_week_wizard_view_form" model="ir.ui.view">
        <field name="name">kc.production.plan.week.wizard.form</field>
        <field name="model">kc.production.plan.week.wizard</field>
        <field name="arch" type="xml">
            <form string="Plan semanal por centro">
                <group>
                    <group>
                        <field name="date_ref"/>
                        <field name="date_from" readonly="1"/>
                        <field name="date_to" readonly="1"/>
                    </group>
                    <group>
                        <field name="work_center_id" options="{'no_create': True}"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print" type="object" string="Imprimir PDF"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="kc_production_plan_week_wizard_action" model="ir.actions.act_window">
        <field name="name">Plan semanal por centro</field>
        <field name="res_model">kc.production.plan.week.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="kc_production_plan_month_wizard_view_form" model="ir.ui.view">
        <field name="name">kc.production.plan.month.wizard.form</field>
        <field name="model">kc.production.plan.month.wizard</field>
        <field name="arch" type="xml">
            <form string="Calendario mensual de producción">
                <group>
                    <group>
                        <field name="month"/>
                        <field name="year"/>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="work_center_id" options="{'no_create': True}"/>
                    </group>
                    <group string="Estados a incluir">
                        <field name="include_planned"/>
                        <field name="include_confirmed"/>
                        <field name="include_validated"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print" type="object" string="Imprimir PDF"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="kc_production_plan_month_wizard_action" model="ir.actions.act_window">
        <field name="name">Calendario mensual</field>
        <field name="res_model">kc.production.plan.month.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
