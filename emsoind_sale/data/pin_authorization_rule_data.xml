<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Regla PIN: confirmar OV exige PIN (jefe). El flujo Validado está en emsoind_sale. -->
        <record id="pin_rule_sale_order_confirm" model="kc.pin.authorization.rule">
            <field name="active" eval="True"/>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="operation">confirm</field>
            <field name="domain">[]</field>
            <field name="reason">Confirmación de orden de venta (cotización validada + PIN de jefe)</field>
        </record>
    </data>
</odoo>
