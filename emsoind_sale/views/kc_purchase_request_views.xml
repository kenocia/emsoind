<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="kc_purchase_request_line_view_tree_emsoind" model="ir.ui.view">
        <field name="name">kc.purchase.request.line.list.emsoind</field>
        <field name="model">kc.purchase.request.line</field>
        <field name="inherit_id" ref="kc_purchase_request_v18.kc_purchase_request_line_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vendor_id']" position="attributes">
                <attribute name="domain">['|', ('supplier_rank', '&gt;', 0), ('emsoind_use_in_purchases', '=', True)]</attribute>
            </xpath>
        </field>
    </record>

    <record id="kc_purchase_request_line_view_form_emsoind" model="ir.ui.view">
        <field name="name">kc.purchase.request.line.form.emsoind</field>
        <field name="model">kc.purchase.request.line</field>
        <field name="inherit_id" ref="kc_purchase_request_v18.kc_purchase_request_line_view_form"/>
        <field name="arch" type="xml">
