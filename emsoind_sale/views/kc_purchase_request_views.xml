        <field name="name">kc.purchase.request.merge.rfq.form.emsoind</field>
        <field name="model">kc.purchase.request.merge.rfq</field>
        <field name="inherit_id" ref="kc_purchase_request_v18.kc_purchase_request_merge_rfq_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">['|', ('supplier_rank', '&gt;', 0), ('emsoind_use_in_purchases', '=', True)]</attribute>
            </xpath>
        </field>
    </record>

    <record id="res_config_settings_view_form_emsoind_pr" model="ir.ui.view">
