        <field name="inherit_id" ref="kc_purchase_request_v18.kc_purchase_request_line_make_po_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">['|', ('supplier_rank', '&gt;', 0), ('emsoind_use_in_purchases', '=', True)]</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//field[@name='vendor_id']" position="attributes">
                <attribute name="domain">['|', ('supplier_rank', '&gt;', 0), ('emsoind_use_in_purchases', '=', True)]</attribute>
            </xpath>
