        <field name="name">kc.purchase.request.form.emsoind.vendor</field>
        <field name="model">kc.purchase.request</field>
        <field name="inherit_id" ref="kc_purchase_request_v18.kc_purchase_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']//field[@name='vendor_id']" position="attributes">
                <attribute name="domain">['|', ('supplier_rank', '&gt;', 0), ('emsoind_use_in_purchases', '=', True)]</attribute>
            </xpath>
        </field>
    </record>

