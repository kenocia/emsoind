<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_emsoind_sale" model="ir.ui.view">
        <field name="name">res.config.settings.form.emsoind.sale</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='show_margins']" position="after">
                <setting id="emsoind_auto_section_by_category"
                         string="Secciones automáticas por categoría"
                         help="Crea secciones en cotizaciones/pedidos usando la ruta completa de la categoría del producto (ej. PT / METALMECANICA / DUCTO...).">
                    <field name="emsoind_auto_section_by_category"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
