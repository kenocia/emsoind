<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_sale_production_order" model="ir.actions.report">
        <field name="name">Orden de Producción</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">emsoind_sale.report_sale_production_order</field>
        <field name="report_file">emsoind_sale.report_sale_production_order</field>
        <field name="print_report_name">'Orden de Producción - %s' % (object.name)</field>
        <field name="paperformat_id" ref="kc_fiscal_hn_v18.paper_format_carta_hn"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="domain">[('state', 'in', ('sale', 'done'))]</field>
    </record>

    <template id="report_sale_production_order_header">
        <t t-set="company" t-value="doc.company_id"/>
        <t t-set="partner" t-value="doc.partner_id.commercial_partner_id or doc.partner_id"/>
        <t t-set="shipping" t-value="doc._emsoind_get_production_shipping_partner()"/>

        <div style="text-align:center; margin-bottom:8px;">
            <t t-if="company.logo">
                <img t-att-src="image_data_uri(company.logo)"
                     style="max-height:80px; max-width:280px;" alt="Logo"/>
            </t>
            <t t-else="">
                <div style="font-size:22px; font-weight:700; color:#1a4fa0;">
                    <span t-field="company.name"/>
                </div>
            </t>
        </div>

        <div style="border-top:2px solid #1a4fa0; padding-top:8px; margin-bottom:12px; font-size:10px; color:#111827; line-height:1.5;">
            <div style="font-weight:600; color:#111827;">
                <span t-field="company.name"/>
            </div>
            <div>
                <span t-field="company.street"/>
                <t t-if="company.street2">, <span t-field="company.street2"/></t>
            </div>
            <div>
                <t t-set="company_location" t-value="', '.join([p for p in [company.city or '', company.state_id.name if company.state_id else '', company.country_id.name if company.country_id else ''] if p])"/>
                <span t-esc="company_location"/>
            </div>
            <div>
                <span>RTN: </span><strong t-field="company.vat"/>
                <t t-if="company.phone">
                    <span> | Tel: </span><span t-field="company.phone"/>
                </t>
                <t t-if="company.email">
                    <span> | </span><span t-field="company.email"/>
                </t>
            </div>
        </div>

        <div style="font-size:18px; font-weight:700; color:#111827; margin-bottom:10px;">
            Orden de Producción <span t-field="doc.name"/>
        </div>

        <table style="width:100%; border-collapse:collapse; border:1px solid #d1d5db; margin-bottom:12px; font-size:10px; color:#111827;">
            <tr>
                <td style="width:25%; padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Su referencia</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-if="doc.client_order_ref" t-field="doc.client_order_ref"/>
                        <span t-else="" style="color:#111827;">—</span>
                    </div>
                </td>
                <td style="width:25%; padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Fecha de la orden</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-field="doc.date_order" t-options="{'widget': 'datetime'}"/>
                    </div>
                </td>
                <td style="width:25%; padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Vendedor</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-if="doc.user_id" t-field="doc.user_id"/>
                        <span t-else="" style="color:#111827;">—</span>
                    </div>
                </td>
                <td style="width:25%; padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Correo</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-if="doc.user_id and doc.user_id.email" t-field="doc.user_id.email"/>
                        <span t-else="" style="color:#111827;">—</span>
                    </div>
                </td>
            </tr>
            <tr>
                <td style="padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Cliente</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-field="partner.name"/>
                    </div>
                </td>
                <td style="padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">RTN</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-if="partner.vat" t-field="partner.vat"/>
                        <span t-else="" style="color:#111827;">—</span>
                    </div>
                </td>
                <td colspan="2" style="padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Dirección entrega</div>
                    <div style="font-weight:600; color:#111827;">
                        <span t-field="shipping.contact_address"/>
                    </div>
                </td>
            </tr>
            <tr>
                <td style="padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Proyecto</div>
                    <div style="font-weight:600; color:#111827;">
                        <t t-if="'project_id' in doc._fields and doc.project_id">
                            <span t-field="doc.project_id"/>
                        </t>
                        <span t-else="" style="color:#111827;">—</span>
                    </div>
                </td>
                <td colspan="3" style="padding:6px 8px; border:1px solid #e5e7eb; vertical-align:top;">
                    <div style="font-size:9px; color:#111827; text-transform:uppercase; margin-bottom:2px;">Fecha entrega</div>
                    <div style="font-weight:600; color:#111827;">
                        <t t-if="doc.commitment_date">
                            <span t-field="doc.commitment_date" t-options="{'widget': 'datetime'}"/>
                        </t>
                        <span t-else="" style="color:#111827;">—</span>
                    </div>
                </td>
            </tr>
        </table>
    </template>

    <template id="report_sale_production_order_signatures">
        <div style="margin-top:36px; page-break-inside:avoid;">
            <table style="width:100%; border-collapse:collapse; font-size:10px; color:#111827;">
                <tr>
                    <td style="width:48%; vertical-align:top; padding-right:4%;">
                        <div style="border-top:1px solid #111827; padding-top:6px; margin-top:40px;">
                            <strong>Entregado por</strong>
                        </div>
                        <div style="margin-top:8px;">Nombre: _______________________________</div>
                        <div style="margin-top:6px;">Fecha: _________________________________</div>
                    </td>
                    <td style="width:48%; vertical-align:top;">
                        <div style="border-top:1px solid #111827; padding-top:6px; margin-top:40px;">
                            <strong>Recibido en producción</strong>
                        </div>
                        <div style="margin-top:8px;">Nombre: _______________________________</div>
                        <div style="margin-top:6px;">Fecha: _________________________________</div>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <template id="report_sale_production_order_document">
        <t t-call="web.basic_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
            <t t-set="report_pages" t-value="doc._emsoind_get_production_report_pages()"/>
            <t t-set="total_pages" t-value="len(report_pages)"/>
            <t t-set="total_qty" t-value="doc._emsoind_get_production_report_total_qty()"/>
            <t t-set="total_delivered" t-value="doc._emsoind_get_production_report_total_delivered()"/>
            <t t-set="total_weight" t-value="doc._emsoind_get_production_report_total_weight()"/>

            <div class="page">
                <t t-foreach="enumerate(report_pages)" t-as="page_data">
                    <t t-set="page_num" t-value="page_data[0]"/>
                    <t t-set="page_lines" t-value="page_data[1]"/>
                    <t t-set="is_last_page" t-value="page_num == total_pages - 1"/>

                    <t t-if="page_num == 0">
                        <t t-call="emsoind_sale.report_sale_production_order_header"/>
                    </t>

                    <table style="width:100%; border-collapse:collapse; font-size:11px; color:#111827; margin-bottom:8px;">
                        <thead>
                            <tr>
                                <th style="text-align:left; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                    Descripción
                                </th>
                                <th style="width:10%; text-align:right; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                    Cantidad
                                </th>
                                <th style="width:10%; text-align:right; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                    Entregado
                                </th>
                                <th style="width:10%; text-align:right; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                    Peso
                                </th>
                                <th style="width:8%; text-align:center; font-size:10px; font-weight:600; letter-spacing:0.8px; color:#111827; text-transform:uppercase; padding:6px 4px; border-bottom:2px solid #1a4fa0;">
                                    Terminado
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_counter" t-value="0"/>
                            <t t-foreach="page_lines" t-as="line">
                                <tr t-att-style="'background-color:#fafbfc; -webkit-print-color-adjust:exact;' if line_counter % 2 == 0 and not line.display_type else ''"
                                    style="page-break-inside:avoid;">
                                    <t t-if="not line.display_type">
                                        <td style="padding:5px 4px; border-bottom:1px solid #eef0f3; vertical-align:top;">
                                            <div style="font-weight:600; color:#111827;">
                                                <span t-esc="line._emsoind_get_production_line_description()"/>
                                            </div>
                                        </td>
                                        <td class="text-end" style="padding:5px 4px; border-bottom:1px solid #eef0f3; white-space:nowrap;">
                                            <span t-field="line.product_uom_qty"/>
                                            <span t-if="line.product_uom" style="font-size:9px; color:#111827;">
                                                <span t-field="line.product_uom"/>
                                            </span>
                                        </td>
                                        <td class="text-end" style="padding:5px 4px; border-bottom:1px solid #eef0f3; white-space:nowrap;">
                                            <span t-field="line.qty_delivered"/>
                                            <span t-if="line.product_uom" style="font-size:9px; color:#111827;">
                                                <span t-field="line.product_uom"/>
                                            </span>
                                        </td>
                                        <td class="text-end" style="padding:5px 4px; border-bottom:1px solid #eef0f3; white-space:nowrap;">
                                            <span t-esc="'%.2f' % line._emsoind_get_production_line_weight()"/>
                                            <t t-if="line.product_id and line.product_id.weight_uom_name">
                                                <span style="font-size:9px; color:#111827;">
                                                    <span t-esc="line.product_id.weight_uom_name"/>
                                                </span>
                                            </t>
                                        </td>
                                        <td class="text-center" style="padding:5px 4px; border-bottom:1px solid #eef0f3; vertical-align:middle;">
                                            <div style="width:14px; height:14px; border:1.5px solid #111827; margin:0 auto; -webkit-print-color-adjust:exact;"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="5" style="padding:6px 4px; font-weight:600; color:#111827; border-bottom:1px solid #eef0f3; background-color:#f3f4f6; -webkit-print-color-adjust:exact;">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="5" style="padding:5px 4px; color:#111827; border-bottom:1px solid #eef0f3;">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </td>
                                    </t>
                                </tr>
                                <t t-set="line_counter" t-value="line_counter + 1"/>
                            </t>
                            <t t-if="is_last_page">
                                <tr style="font-weight:700; color:#111827;">
                                    <td style="padding:6px 4px; border-top:2px solid #1a4fa0; text-align:right;">
                                        Total:
                                    </td>
                                    <td class="text-end" style="padding:6px 4px; border-top:2px solid #1a4fa0;">
                                        <span t-esc="total_qty"/>
                                    </td>
                                    <td class="text-end" style="padding:6px 4px; border-top:2px solid #1a4fa0;">
                                        <span t-esc="total_delivered"/>
                                    </td>
                                    <td class="text-end" style="padding:6px 4px; border-top:2px solid #1a4fa0;">
                                        <span t-esc="'%.2f' % total_weight"/>
                                    </td>
                                    <td style="padding:6px 4px; border-top:2px solid #1a4fa0;"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <t t-if="is_last_page">
                        <t t-if="doc.note">
                            <div style="font-size:10px; color:#111827; margin-top:8px; page-break-inside:avoid;">
                                <div style="font-weight:600; color:#111827; margin-bottom:4px;">Observaciones</div>
                                <span t-field="doc.note"/>
                            </div>
                        </t>
                        <t t-call="emsoind_sale.report_sale_production_order_signatures"/>
                    </t>

                    <t t-if="not is_last_page">
                        <div style="page-break-before:always;"/>
                    </t>
                </t>
            </div>
        </t>
    </template>

    <template id="report_sale_production_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="emsoind_sale.report_sale_production_order_document"
                   t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>
