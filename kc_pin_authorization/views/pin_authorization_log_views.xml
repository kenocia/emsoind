<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kc_pin_authorization_log_list" model="ir.ui.view">
        <field name="name">kc.pin.authorization.log.list</field>
        <field name="model">kc.pin.authorization.log</field>
        <field name="arch" type="xml">
            <list string="Autorizaciones por PIN" create="false" edit="false"
                  decoration-danger="result == 'fail'"
                  decoration-success="result == 'success'">
                <field name="authorization_date"/>
                <field name="employee_id"/>
                <field name="user_id"/>
                <field name="reason"/>
                <field name="document_ref"/>
                <field name="result"/>
            </list>
        </field>
    </record>

    <record id="view_kc_pin_authorization_log_form" model="ir.ui.view">
        <field name="name">kc.pin.authorization.log.form</field>
        <field name="model">kc.pin.authorization.log</field>
        <field name="arch" type="xml">
            <form string="Autorización por PIN" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="user_id"/>
                            <field name="authorization_date"/>
                            <field name="result"/>
                        </group>
                        <group>
                            <field name="reason"/>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="document_ref"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kc_pin_authorization_log_search" model="ir.ui.view">
        <field name="name">kc.pin.authorization.log.search</field>
        <field name="model">kc.pin.authorization.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="user_id"/>
                <field name="reason"/>
                <filter name="filter_success" string="Autorizados"
                        domain="[('result', '=', 'success')]"/>
                <filter name="filter_fail" string="PIN incorrecto"
                        domain="[('result', '=', 'fail')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_employee" string="Empleado"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_result" string="Resultado"
                            context="{'group_by': 'result'}"/>
                    <filter name="group_date" string="Fecha"
                            context="{'group_by': 'authorization_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kc_pin_authorization_log" model="ir.actions.act_window">
        <field name="name">Autorizaciones por PIN</field>
        <field name="res_model">kc.pin.authorization.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_kc_pin_authorization_log"
              name="Auditoría"
              parent="menu_kc_pin_authorization_root"
              action="action_kc_pin_authorization_log"
              groups="base.group_system"
              sequence="20"/>
</odoo>
