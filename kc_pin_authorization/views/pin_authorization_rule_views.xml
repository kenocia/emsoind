<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kc_pin_authorization_rule_list" model="ir.ui.view">
        <field name="name">kc.pin.authorization.rule.list</field>
        <field name="model">kc.pin.authorization.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de Autorización por PIN" editable="bottom">
                <field name="model_id" options="{'no_create': True}"/>
                <field name="model_name" column_invisible="1"/>
                <field name="operation"/>
                <field name="domain" widget="domain"
                       options="{'model': 'model_name'}"/>
                <field name="reason"/>
                <field name="company_id" groups="base.group_multi_company"
                       optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_kc_pin_authorization_rule_form" model="ir.ui.view">
        <field name="name">kc.pin.authorization.rule.form</field>
        <field name="model">kc.pin.authorization.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Autorización por PIN">
                <sheet>
                    <widget name="web_ribbon" title="Archivada"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="model_id" options="{'no_create': True}"/>
                            <field name="model_name" invisible="1"/>
                            <field name="operation"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="reason"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <separator string="Filtro (opcional) — acota a un sub-tipo"/>
                    <p class="text-muted">
                        Deje vacío para aplicar a todos los registros de la
                        operación. Ejemplo recepción:
                        <code>[("picking_type_code", "=", "incoming")]</code>.
                    </p>
                    <field name="domain" widget="domain"
                           options="{'model': 'model_name'}" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kc_pin_authorization_rule_search" model="ir.ui.view">
        <field name="name">kc.pin.authorization.rule.search</field>
        <field name="model">kc.pin.authorization.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_id"/>
                <field name="reason"/>
                <filter name="filter_active" string="Activas"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Archivadas"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_model" string="Documento"
                            context="{'group_by': 'model_id'}"/>
                    <filter name="group_operation" string="Operación"
                            context="{'group_by': 'operation'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kc_pin_authorization_rule" model="ir.actions.act_window">
        <field name="name">Reglas de Autorización por PIN</field>
        <field name="res_model">kc.pin.authorization.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cree una regla de autorización por PIN
            </p>
            <p>
                Indique el documento y la operación en la que se exigirá el PIN
                antes de validar (p. ej. Inventario → Validar, filtrando por
                recepción o despacho).
            </p>
        </field>
    </record>

    <menuitem id="menu_kc_pin_authorization_root"
              name="Autorización por PIN"
              parent="base.menu_administration"
              groups="base.group_system"
              sequence="89"/>

    <menuitem id="menu_kc_pin_authorization_rule"
              name="Reglas"
              parent="menu_kc_pin_authorization_root"
              action="action_kc_pin_authorization_rule"
              sequence="10"/>
</odoo>
